---
import Base from "../../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("podcast");
  return posts.map((post: CollectionEntry<"podcast">) => ({
    params: { slug: post.id.replace("transcripts/", "") },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"podcast">;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={post.data.title ?? "Transcript"}
  description={`Front End Nerdery Podcast transcript — ${post.data.title}`}
>
  <article aria-labelledby="transcript-heading">
    <header class="transcript-header">
      <h1 id="transcript-heading" class="post-title">{post.data.title}</h1>
      <a href="/podcast" class="post-back">cd ../podcast</a>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <footer class="post-footer">
      <a href="/podcast" class="post-back">cd ../podcast</a>
    </footer>
  </article>
</Base>

<style>
  .transcript-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 0.5px solid var(--warm-border);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .post-content {
    font-size: 0.9375rem;
    color: var(--text-primary);
    line-height: 1.75;
  }

  :global(.post-content p) {
    margin-bottom: 1.25rem;
  }

  :global(.post-content a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  :global(.post-content a:hover) {
    opacity: 0.75;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 0.5px solid var(--warm-border);
  }

  .post-back {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-back:hover {
    opacity: 0.8;
  }
</style>
