---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 5);

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Web developer and accessibility advocate based in Phoenix, AZ.",
  image,
} = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#252C37" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title + " · Todd Libby"} />
    <meta property="og:description" content={description} />
    <meta
      property="og:url"
      content={`https://toddl.dev${Astro.url.pathname}`}
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:image"
      content={image ??
        "https://res.cloudinary.com/colabottles/image/upload/v1731376889/todd-social-card-names.png"}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title + " · Todd Libby"} />
    <meta name="twitter:description" content={description} />
    <title>{title} · Todd Libby</title>
    <script is:inline>
      const stored = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      const theme = stored ?? (prefersDark ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>
  <body>
    <header>
      <a href="#main-content" class="skip-link">skip to main content</a>
    </header>

    <aside class="sidebar" id="sidebar" aria-label="Site navigation">
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Switch to light mode"
      >
        <svg
          role="img"
          class="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          focusable="false"
        >
          <title>Switch to light mode</title>
          <circle cx="12" cy="12" r="4"></circle>
          <line x1="12" y1="2" x2="12" y2="4"></line>
          <line x1="12" y1="20" x2="12" y2="22"></line>
          <line x1="4.93" y1="4.93" x2="6.34" y2="6.34"></line>
          <line x1="17.66" y1="17.66" x2="19.07" y2="19.07"></line>
          <line x1="2" y1="12" x2="4" y2="12"></line>
          <line x1="20" y1="12" x2="22" y2="12"></line>
          <line x1="4.93" y1="19.07" x2="6.34" y2="17.66"></line>
          <line x1="17.66" y1="6.34" x2="19.07" y2="4.93"></line>
        </svg>
        <svg
          role="img"
          class="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          focusable="false"
        >
          <title>Switch to dark mode</title>
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <div>
        <p class="sidebar__prompt">~/toddl $</p>
        <p class="sidebar__name">Todd Libby</p>
        <p class="sidebar__role">Web Developer</p>
      </div>

      <Nav currentPath={currentPath} />

      <section class="webring" aria-labelledby="webring-heading">
        <h2 id="webring-heading" class="webring__title">a11y-webring.club</h2>
        <p class="webring__desc">
          This site is a member of the <a
            href="https://a11y-webring.club/"
            class="webring__link"
            target="_blank"
            rel="noopener noreferrer">a11y-webring.club</a
          >.
        </p>
        <nav aria-label="a11y webring navigation">
          <ul class="webring__links">
            <li>
              <a
                href="https://a11y-webring.club/prev"
                class="webring__link"
                rel="external">Previous</a
              >
            </li>
            <li>
              <a
                href="https://a11y-webring.club/random"
                class="webring__link"
                rel="external">Random</a
              >
            </li>
            <li>
              <a
                href="https://a11y-webring.club/next"
                class="webring__link"
                rel="external">Next</a
              >
            </li>
          </ul>
        </nav>
      </section>

      <section class="stack" aria-labelledby="stack-heading">
        <h2 id="stack-heading" class="stack__label">stack</h2>
        <ul class="stack__chips">
          {
            ["Nuxt 4", "TypeScript"].map((s) => (
              <li>
                <span class="chip chip--hi">{s}</span>
              </li>
            ))
          }
          {
            ["Supabase", "Netlify", "Astro", "WCAG 2.2", "Node"].map((s) => (
              <li>
                <span class="chip">{s}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>

    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="sidebar"
    >
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
    </button>

    <div class="layout" id="layout">
      <main class="main" id="main-content" tabindex="-1">
        <slot />
      </main>

      <aside
        class="right-panel"
        id="right-panel"
        aria-label="Support and GitHub"
      >
        <div class="right-panel__top">
          <button
            class="gh-toggle"
            id="gh-toggle"
            aria-label="Open GitHub panel"
            aria-expanded="false"
            aria-controls="gh-panel"
          >
            <svg
              role="img"
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              focusable="false"
            >
              <title>GitHub</title>
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path>
            </svg>
          </button>
        </div>

        <section
          class="support-panel"
          id="support-panel"
          aria-labelledby="sponsor-heading"
        >
          <h2 id="sponsor-heading" class="support-panel__title">
            support my work
          </h2>
          <p class="support-panel__pitch">
            I build accessible, open-source tools and write about web
            accessibility. If my work has helped you, consider sponsoring or
            advertising here.
          </p>
          <ul class="support-panel__links">
            <li>
              <a
                href="https://github.com/sponsors/colabottles"
                class="support-link support-link--gh"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  focusable="false"
                >
                  <path
                    d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                  ></path>
                </svg>
                GitHub Sponsors
              </a>
            </li>
            <li>
              <a
                href="https://ko-fi.com/Y8Y727FD2"
                class="support-link support-link--kofi"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  focusable="false"
                >
                  <path
                    d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.483-2.566 2.483-2.566s-.016-1.682.104-3.937c.148-3.053 1.547-3.513 1.547-3.513h1.585c1.995 0 3.357 1.106 3.357 3.357 0 1.784-1.32 2.748-2.89 2.748H20.29c-.708 0-1.027.607-1.027 1.152 0 .803.645 1.229 1.027 1.229h.938c2.527 0 5.009-1.47 5.009-4.613a5.058 5.058 0 0 0-2.366-4.266zM5.393 14.5H3.107V7h2.286v7.5zm5.357 0H8.464V7h2.286v7.5z"
                  ></path>
                </svg>
                Ko-fi
              </a>
            </li>
            <li>
              <a href="/contact" class="support-link support-link--ad"
                >advertise here</a
              >
            </li>
          </ul>
        </section>

        <section class="recent-posts" aria-labelledby="recent-posts-heading">
          <h2 id="recent-posts-heading" class="recent-posts__title">
            recent posts
          </h2>
          <ul class="recent-posts__list">
            {
              recentPosts.map((post) => (
                <li class="recent-post">
                  <a href={`/blog/${post.id}`} class="recent-post__link">
                    <span class="recent-post__title">{post.data.title}</span>
                    <span class="recent-post__date">
                      {new Date(post.data.date).toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                      })}
                    </span>
                    {post.data.bskyPostId && (
                      <span
                        class="recent-post__likes"
                        data-bsky-id={post.data.bskyPostId}
                      >
                        🦋 —
                      </span>
                    )}
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <aside
          class="gh-panel"
          id="gh-panel"
          aria-label="GitHub profile"
          aria-hidden="true"
        >
          <header class="gh-panel__header">
            <h2 class="gh-panel__title">GitHub</h2>
            <button
              class="gh-panel__close"
              id="gh-close"
              aria-label="Close GitHub panel"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                focusable="false"
              >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </header>
          <div class="gh-panel__body" id="gh-body">
            <p class="gh-loading">Loading...</p>
          </div>
        </aside>
      </aside>
    </div>

    <button
      class="right-panel-btn"
      id="right-panel-btn"
      aria-label="Open support and GitHub panel"
      aria-expanded="false"
      aria-controls="right-panel"
    >
      <svg
        role="img"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        focusable="false"
      >
        <title>Support and GitHub</title>
        <path
          d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
        ></path>
      </svg>
    </button>

    <script>
      const hamburger = document.getElementById("hamburger")!;
      const sidebar = document.getElementById("sidebar")!;
      const overlay = document.getElementById("sidebar-overlay")!;
      const toggle = document.getElementById("theme-toggle")!;
      const ghToggle = document.getElementById("gh-toggle")!;
      const ghPanel = document.getElementById("gh-panel")!;
      const ghClose = document.getElementById("gh-close")!;
      const ghBody = document.getElementById("gh-body")!;
      const sponsorPanel = document.getElementById("support-panel")!;

      function trapFocus(e: KeyboardEvent) {
        const focusable = Array.from(
          sidebar.querySelectorAll(
            "button, a, [tabindex]:not([tabindex='-1'])",
          ),
        ) as HTMLElement[];
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.key === "Tab") {
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }

      function openMenu() {
        sidebar.classList.add("is-open");
        overlay.classList.add("is-open");
        hamburger.setAttribute("aria-expanded", "true");
        hamburger.setAttribute("aria-label", "Close navigation menu");
        document.body.style.overflow = "hidden";
        const firstFocusable = sidebar.querySelector(
          "button, a",
        ) as HTMLElement;
        firstFocusable?.focus();
        sidebar.addEventListener("keydown", trapFocus);
      }

      function closeMenu() {
        sidebar.classList.remove("is-open");
        overlay.classList.remove("is-open");
        hamburger.setAttribute("aria-expanded", "false");
        hamburger.setAttribute("aria-label", "Open navigation menu");
        document.body.style.overflow = "";
        sidebar.removeEventListener("keydown", trapFocus);
        hamburger.focus();
      }

      hamburger.addEventListener("click", () => {
        sidebar.classList.contains("is-open") ? closeMenu() : openMenu();
      });

      overlay.addEventListener("click", closeMenu);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          closeMenu();
          closeGH();
        }
      });

      function applyTheme(theme: string) {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
        toggle.setAttribute(
          "aria-label",
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode",
        );
      }

      toggle.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme");
        applyTheme(current === "dark" ? "light" : "dark");
      });

      const storedTheme = localStorage.getItem("theme");
      if (storedTheme) {
        toggle.setAttribute(
          "aria-label",
          storedTheme === "dark"
            ? "Switch to light mode"
            : "Switch to dark mode",
        );
      }

      let ghLoaded = false;

      async function loadGitHub() {
        if (ghLoaded) return;
        ghLoaded = true;
        try {
          const [profileRes, reposRes, eventsRes] = await Promise.all([
            fetch("https://api.github.com/users/colabottles"),
            fetch(
              "https://api.github.com/users/colabottles/repos?sort=updated&per_page=5",
            ),
            fetch(
              "https://api.github.com/users/colabottles/events/public?per_page=10",
            ),
          ]);

          const profile = await profileRes.json();
          const repos = await reposRes.json();
          const events = await eventsRes.json();

          const typeMap: Record<string, string> = {
            PushEvent: "pushed to",
            PullRequestEvent: "PR on",
            IssuesEvent: "issue on",
            CreateEvent: "created branch in",
            DeleteEvent: "deleted branch in",
            WatchEvent: "starred",
            ForkEvent: "forked",
            ReleaseEvent: "released",
            IssueCommentEvent: "commented on",
          };

          ghBody.innerHTML = `
            <section class="gh-section" aria-labelledby="gh-profile-heading">
              <h3 id="gh-profile-heading" class="gh-section__title">profile</h3>
              <dl class="gh-profile">
                <div class="gh-profile__row"><dt>followers</dt><dd>${profile.followers}</dd></div>
                <div class="gh-profile__row"><dt>following</dt><dd>${profile.following}</dd></div>
                <div class="gh-profile__row"><dt>public repos</dt><dd>${profile.public_repos}</dd></div>
                <div class="gh-profile__row"><dt>member since</dt><dd>${new Date(profile.created_at).getFullYear()}</dd></div>
              </dl>
            </section>
            <section class="gh-section" aria-labelledby="gh-repos-heading">
              <h3 id="gh-repos-heading" class="gh-section__title">recent repos</h3>
              <ul class="gh-repos">
                ${repos
                  .map(
                    (r: any) => `
                  <li class="gh-repo">
                    <a href="${r.html_url}" class="gh-repo__name" target="_blank" rel="noopener noreferrer">${r.name}</a>
                    ${r.description ? `<p class="gh-repo__desc">${r.description}</p>` : ""}
                    <p class="gh-repo__meta">
                      ${r.language ? `<span class="gh-repo__lang">${r.language}</span>` : ""}
                      <span class="gh-repo__stars">&#9733; ${r.stargazers_count}</span>
                    </p>
                  </li>
                `,
                  )
                  .join("")}
              </ul>
            </section>
            <section class="gh-section" aria-labelledby="gh-activity-heading">
              <h3 id="gh-activity-heading" class="gh-section__title">recent activity</h3>
              <ul class="gh-events">
                ${events
                  .slice(0, 8)
                  .map((e: any) => {
                    const action =
                      typeMap[e.type] ?? e.type.replace("Event", "");
                    const repo = e.repo.name.split("/")[1];
                    const branch = e.payload?.ref ? ` (${e.payload.ref})` : "";
                    return `<li class="gh-event"><span class="gh-event__action">${action}</span> <span class="gh-event__repo">${repo}${branch}</span></li>`;
                  })
                  .join("")}
              </ul>
            </section>
          `;
        } catch {
          ghBody.innerHTML = `<p class="gh-error">Could not load GitHub data.</p>`;
        }
      }

      function openGH() {
        ghPanel.classList.add("is-open");
        ghPanel.removeAttribute("aria-hidden");
        sponsorPanel.setAttribute("aria-hidden", "true");
        sponsorPanel.classList.add("is-hidden");
        ghToggle.setAttribute("aria-expanded", "true");
        ghToggle.setAttribute("aria-label", "Close GitHub panel");
        loadGitHub();
      }

      function closeGH() {
        ghPanel.classList.remove("is-open");
        ghPanel.setAttribute("aria-hidden", "true");
        sponsorPanel.removeAttribute("aria-hidden");
        sponsorPanel.classList.remove("is-hidden");
        ghToggle.setAttribute("aria-expanded", "false");
        ghToggle.setAttribute("aria-label", "Open GitHub panel");
      }

      ghToggle.addEventListener("click", () => {
        ghPanel.classList.contains("is-open") ? closeGH() : openGH();
      });

      ghClose.addEventListener("click", closeGH);

      const rightPanelBtn = document.getElementById("right-panel-btn");
      const rightPanel = document.getElementById("right-panel");

      if (rightPanelBtn && rightPanel) {
        rightPanelBtn.addEventListener("click", () => {
          const isOpen = rightPanel.classList.contains("mobile-open");
          rightPanel.classList.toggle("mobile-open");
          rightPanelBtn.setAttribute(
            "aria-expanded",
            isOpen ? "false" : "true",
          );
          if (!isOpen) {
            document.body.style.overflow = "hidden";
          } else {
            document.body.style.overflow = "";
          }
        });
      }

      // Fetch Bluesky likes for recent posts
      const likeEls = document.querySelectorAll("[data-bsky-id]");
      if (likeEls.length > 0) {
        const myDid = "did:plc:gevyqibw5p2xsonkbsbjm5vy";
        for (const el of likeEls) {
          const id = el.getAttribute("data-bsky-id");
          if (!id) continue;
          try {
            const res = await fetch(
              `https://public.api.bsky.app/xrpc/app.bsky.feed.getPosts?uris=at://${myDid}/app.bsky.feed.post/${id}`,
            );
            const data = await res.json();
            const count = data.posts?.[0]?.likeCount ?? 0;
            el.textContent = `🦋 ${count}`;
          } catch {
            el.textContent = "";
          }
        }
      }
    </script>
  </body>
</html>
