---
import Base from "../layouts/Base.astro";
---

<Base title="Colophon" description="How this site was built.">
  <section aria-labelledby="colophon-heading">
    <h1 id="colophon-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> cat ./colophon
    </h1>

    <dl class="colophon-list">
      <div class="colophon-group">
        <dt class="colophon-group__label">built with</dt>
        <dd class="colophon-group__items">
          <ul>
            <li class="colophon-item">
              <strong>Astro</strong>
              <span class="colophon-note">static site generator</span>
            </li>
            <li class="colophon-item">
              <strong>Vue 3</strong>
              <span class="colophon-note">interactive islands</span>
            </li>
            <li class="colophon-item">
              <strong>Vanilla CSS</strong>
              <span class="colophon-note">no frameworks, no utilities</span>
            </li>
            <li class="colophon-item">
              <strong>TypeScript</strong>
              <span class="colophon-note">always</span>
            </li>
          </ul>
        </dd>
      </div>

      <div class="colophon-group">
        <dt class="colophon-group__label">deployed to</dt>
        <dd class="colophon-group__items">
          <ul>
            <li class="colophon-item">
              <strong>Netlify</strong>
              <span class="colophon-note">CI/CD + CDN</span>
            </li>
          </ul>
        </dd>
      </div>

      <div class="colophon-group">
        <dt class="colophon-group__label">typeface</dt>
        <dd class="colophon-group__items">
          <ul>
            <li class="colophon-item">
              <strong>JetBrains Mono</strong>
              <span class="colophon-note">monospace throughout</span>
            </li>
          </ul>
        </dd>
      </div>

      <div class="colophon-group">
        <dt class="colophon-group__label">colors</dt>
        <dd class="colophon-group__items">
          <ul>
            <li class="colophon-item">
              <span class="swatch" style="background:#a3af7c"></span><strong
                >#a3af7c</strong
              >
              <span class="colophon-note">accent (dark mode)</span>
            </li>
            <li class="colophon-item">
              <span class="swatch" style="background:#3a6200"></span><strong
                >#3a6200</strong
              >
              <span class="colophon-note">accent (light mode)</span>
            </li>
            <li class="colophon-item">
              <span class="swatch" style="background:#252C37"></span><strong
                >#252C37</strong
              >
              <span class="colophon-note">sidebar</span>
            </li>
            <li class="colophon-item">
              <span
                class="swatch"
                style="background:#f8f7f4; border: 0.5px solid #ccc"
              ></span><strong>#f8f7f4</strong>
              <span class="colophon-note">warm background</span>
            </li>
          </ul>
        </dd>
      </div>

      <div class="colophon-group">
        <dt class="colophon-group__label">accessibility</dt>
        <dd class="colophon-group__items">
          <ul>
            <li class="colophon-item">WCAG 2.2 AA compliant</li>
            <li class="colophon-item">Semantic HTML5 throughout</li>
            <li class="colophon-item">Tested with NVDA, JAWS, and VoiceOver</li>
            <li class="colophon-item">Keyboard navigable</li>
            <li class="colophon-item">Respects prefers-reduced-motion</li>
            <li class="colophon-item">
              Light and dark mode via prefers-color-scheme
            </li>
          </ul>
        </dd>
      </div>

      <div class="colophon-group">
        <dt class="colophon-group__label">design</dt>
        <dd class="colophon-group__items">
          <ul>
            <li class="colophon-item">Terminal-inspired aesthetic</li>
            <li class="colophon-item">
              Persistent dark sidebar, warm content area
            </li>
            <li class="colophon-item">No tracking, no analytics, no ads</li>
          </ul>
        </dd>
      </div>
    </dl>
  </section>
</Base>

<style>
  .colophon-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .colophon-group {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0.75rem;
    padding: 0.75rem 0.875rem;
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    background: var(--warm-mid);
    align-items: start;
  }

  .colophon-group__label {
    font-size: 0.75rem;
    color: var(--accent);
    padding-top: 0.125rem;
  }

  .colophon-group__items ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .colophon-item {
    font-size: 0.875rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .colophon-item strong {
    font-weight: 500;
  }

  .colophon-note {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .colophon-note::before {
    content: "// ";
    color: var(--accent);
    opacity: 0.6;
  }

  .swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }
</style>
