---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const date = new Date(post.data.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const bskyPostId = post.data.bskyPostId ?? null;
const myDid = "did:plc:gevyqibw5p2xsonkbsbjm5vy";
const bskyHandle = "toddl.dev";
---

<Base title={post.data.title} description={post.data.description}>
  <article aria-labelledby="post-heading">
    <header class="post-header">
      <h1 id="post-heading" class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time class="post-date" datetime={post.data.date.toISOString()}
          >{date}</time
        >
        {
          post.data.tags && post.data.tags.length > 0 && (
            <ul class="post-tags" aria-label="Tags">
              {post.data.tags.map((tag: string) => (
                <li class="post-tag">{tag}</li>
              ))}
            </ul>
          )
        }
      </div>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <footer class="post-footer">
      {
        bskyPostId && (
          <section
            class="bsky-likes"
            data-bsky-container
            aria-labelledby="bsky-likes-heading"
          >
            <meta data-bsky-post-id={bskyPostId} />
            <h2 id="bsky-likes-heading" class="bsky-likes__title">
              <span aria-hidden="true">🦋</span>
              <span data-bsky-likes-count>0</span> likes on Bluesky
            </h2>
            <a
              class="bsky-likes__cta"
              href={`https://bsky.app/profile/${bskyHandle}/post/${bskyPostId}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              Like this post on Bluesky to see your face here
            </a>
            <ul
              data-bsky-likes
              class="bsky-likes__list"
              aria-label="People who liked this post on Bluesky"
            />
          </section>
        )
      }
      <a href="/blog" class="post-back">cd ../blog</a>
    </footer>
  </article>
</Base>

<style>
  article {
    max-width: 72ch;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 0.5px solid var(--warm-border);
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: 0.875rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .post-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-tag {
    font-size: 0.75rem;
    color: var(--accent);
    border: 0.5px solid var(--accent-border);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.5rem;
  }

  .post-content {
    font-size: 0.9375rem;
    color: var(--text-primary);
    line-height: 1.75;
  }

  :global(.post-content p) {
    margin-bottom: 1.25rem;
  }

  :global(.post-content h2) {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 2rem 0 0.875rem;
    padding-bottom: 0.375rem;
    border-bottom: 0.5px solid var(--warm-border);
  }

  :global(.post-content h3) {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 1.75rem 0 0.75rem;
  }

  :global(.post-content h4) {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--accent);
    margin: 1.5rem 0 0.5rem;
  }

  :global(.post-content a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  :global(.post-content a:hover) {
    opacity: 0.75;
  }

  :global(.post-content ul),
  :global(.post-content ol) {
    margin: 0.75rem 0 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  :global(.post-content ul) {
    list-style: disc;
  }

  :global(.post-content ol) {
    list-style: decimal;
  }

  :global(.post-content li) {
    color: var(--text-primary);
    line-height: 1.7;
    margin: 0.5rem 0 0.5rem 1.5rem;
  }

  :global(.post-content li::marker) {
    color: var(--accent);
  }

  :global(.post-content blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    background: var(--warm-mid);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  :global(.post-content blockquote p) {
    margin-bottom: 0;
  }

  :global(.post-content pre) {
    background: #1a1f27;
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    overflow-x: auto;
    font-size: 0.875rem;
    margin: 2rem 0;
    line-height: 1.7;
    color: #e2dfd8;
  }

  :global(.post-content code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--accent);
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    padding: 0.2rem 0.45rem;
    border-radius: 3px;
  }

  :global(.post-content pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  :global(.post-content img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
    border: 0.5px solid var(--warm-border);
  }

  :global(.post-content hr) {
    border: none;
    border-top: 0.5px solid var(--warm-border);
    margin: 2rem 0;
  }

  /* Bluesky likes */
  .bsky-likes {
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-md);
    min-height: 200px;
  }

  .bsky-likes__title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bsky-likes__cta {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: block;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .bsky-likes__cta:hover {
    opacity: 0.8;
  }

  .bsky-likes__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
  }

  .bsky-like {
    width: 3rem;
    aspect-ratio: 1/1;
    margin-right: -0.75rem;
    border-radius: 100%;
    filter: drop-shadow(0px 1px 2px rgba(0, 0, 0, 0.25));
  }

  .bsky-like__avatar {
    width: 100%;
    height: 100%;
    border-radius: 100%;
    object-fit: cover;
  }

  .bsky-like--placeholder,
  .bsky-like--more {
    width: 3rem;
    aspect-ratio: 1/1;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 500;
    background-color: #208bfe;
    color: #fff;
    border-radius: 100%;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 0.5px solid var(--warm-border);
  }

  .post-back {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-back:hover {
    opacity: 0.8;
  }
</style>

<script>
  const LIMIT = 55;
  const myDid = "did:plc:gevyqibw5p2xsonkbsbjm5vy";
  const bskyAPI = "https://public.api.bsky.app/xrpc/";
  const getLikesURL = `${bskyAPI}app.bsky.feed.getLikes?limit=${LIMIT}&uri=`;
  const getPostURL = `${bskyAPI}app.bsky.feed.getPosts?uris=`;

  const metaEl = document.querySelector(
    "[data-bsky-post-id]",
  ) as HTMLMetaElement | null;
  const container = document.querySelector("[data-bsky-container]");
  const likesContainer = document.querySelector("[data-bsky-likes]");
  const likesCount = document.querySelector("[data-bsky-likes-count]");

  if (!metaEl || !container || !likesContainer || !likesCount) {
    // no bskyPostId on this post, nothing to do
  } else {
    const bskyPostId = metaEl.dataset.bskyPostId;

    if (bskyPostId) {
      const postUri = `at://${myDid}/app.bsky.feed.post/${bskyPostId}`;

      function drawHowManyMore(
        postLikesCount: number,
        likesActorLength: number,
      ) {
        if (postLikesCount > LIMIT) {
          const likesMore = document.createElement("li");
          likesMore.classList.add("bsky-like", "bsky-like--more");
          likesMore.textContent = `+${postLikesCount - likesActorLength}`;
          likesContainer!.appendChild(likesMore);
        }
      }

      function drawLikes(likesActors: any[], postLikesCount: number) {
        for (const like of likesActors) {
          const likeEl = document.createElement("li");
          likeEl.classList.add("bsky-like");

          if (like.actor.avatar) {
            likeEl.innerHTML = `<img class="bsky-like__avatar" src="${like.actor.avatar.replace("avatar", "avatar_thumbnail")}" alt="${like.actor.displayName ?? like.actor.handle}" width="48" height="48" loading="lazy" />`;
          } else {
            likeEl.classList.add("bsky-like--placeholder");
            likeEl.innerHTML = `<span aria-label="${like.actor.displayName ?? like.actor.handle}">@</span>`;
          }

          likesContainer!.appendChild(likeEl);
        }
        drawHowManyMore(postLikesCount, likesActors.length);
      }

      try {
        const [bskyPost, bskyPostLikes] = await Promise.all([
          fetch(getPostURL + postUri),
          fetch(getLikesURL + postUri),
        ]);
        const postData = await bskyPost.json();
        const likesData = await bskyPostLikes.json();
        const totalLikesCount = postData.posts[0].likeCount;

        if (likesData.likes.length > 0) {
          likesCount.textContent = totalLikesCount;
          drawLikes(likesData.likes, totalLikesCount);
        } else {
          likesCount.textContent = "0";
        }
      } catch {
        container.remove();
      }
    }
  }
</script>
