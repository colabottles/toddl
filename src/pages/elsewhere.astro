---
import PageLayout from "../layouts/PageLayout.astro";

interface SocialLink {
  platform: string;
  handle: string;
  url: string;
  description: string;
}

const socialLinks: SocialLink[] = [
  {
    platform: "Bluesky",
    handle: "@toddl.dev",
    url: "https://bsky.app/profile/toddl.dev",
    description: "Primary social. Where I post most.",
  },
  {
    platform: "GitHub",
    handle: "colabottles",
    url: "https://github.com/colabottles",
    description: "Code, projects, and open source work.",
  },
  {
    platform: "Twitch",
    handle: "zulkirjax",
    url: "https://twitch.tv/zulkirjax",
    description: "DDO streams, ZulkirBot, and chat RPG chaos.",
  },
  {
    platform: "YouTube",
    handle: "@frontendnerdery",
    url: "https://www.youtube.com/@frontendnerdery",
    description: "Front End Nerdery podcast and talk recordings.",
  },
  {
    platform: "noti.st",
    handle: "colabottles",
    url: "https://noti.st/colabottles",
    description: "Slides from conference talks.",
  },
  {
    platform: "Ko-fi",
    handle: "Y8Y727FD2",
    url: "https://ko-fi.com/Y8Y727FD2",
    description: "Support my work if it's been useful to you.",
  },
  {
    platform: "GitHub Sponsors",
    handle: "colabottles",
    url: "https://github.com/sponsors/colabottles",
    description: "Monthly sponsorship via GitHub.",
  },
];
---

<PageLayout
  title="Elsewhere — Todd Libby"
  pageNumber={5}
  pageLabel="Misc / Elsewhere"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">Around the web</p>
    <p class="intro-text">
      Where to find me outside of toddl.dev — social, code, streams, and
      everything else.
    </p>

    <ul class="social-list" role="list">
      {
        socialLinks.map((link) => (
          <li class="social-item">
            <a href={link.url} class="social-link" rel="noopener noreferrer">
              <div class="social-header">
                <span class="social-platform">{link.platform}</span>
                <span class="social-handle">{link.handle}</span>
              </div>
              <p class="social-desc">{link.description}</p>
            </a>
          </li>
        ))
      }
    </ul>

    <section aria-labelledby="podcast-heading" class="podcast-section">
      <h2 id="podcast-heading" class="content-heading">
        Front End Nerdery Podcast
      </h2>
      <p class="body-text">
        My podcast on web development, accessibility, and the industry.
        Currently on hiatus.
      </p>
      <div class="podcast-links">
        <a
          href="https://open.spotify.com/show/3oEGCFmMvRHgCBQJpiKBFP"
          class="podcast-link"
          rel="noopener noreferrer"
        >
          Spotify
        </a>
        <a
          href="https://www.youtube.com/@frontendnerdery"
          class="podcast-link"
          rel="noopener noreferrer"
        >
          YouTube
        </a>
        <a href="/podcast" class="podcast-link"> Transcripts </a>
      </div>
    </section>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Primary</p>
      <p class="side-heading">Bluesky</p>
      <a
        href="https://bsky.app/profile/toddl.dev"
        class="side-link"
        rel="noopener noreferrer">@toddl.dev</a
      >
    </div>

    <div class="side-item">
      <p class="section-label">Code</p>
      <a
        href="https://github.com/colabottles"
        class="side-link"
        rel="noopener noreferrer">GitHub</a
      >
    </div>

    <div class="side-item">
      <p class="section-label">Stream</p>
      <a
        href="https://twitch.tv/zulkirjax"
        class="side-link"
        rel="noopener noreferrer">Twitch</a
      >
    </div>

    <div class="side-item">
      <p class="section-label">Podcast</p>
      <p class="side-heading">Front End Nerdery</p>
      <p class="side-text">On hiatus.</p>
    </div>

    <div class="side-item">
      <p class="section-label">Back</p>
      <a href="/misc" class="side-link">Misc</a>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .social-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .social-item {
    border-bottom: 1px solid #222;
  }

  .social-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.15s;
  }

  .social-link:hover {
    padding-left: 0.5rem;
  }

  .social-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .social-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .social-platform {
    font-family: "Oswald", sans-serif;
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
  }

  .social-handle {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: #555;
  }

  .social-desc {
    font-size: 0.82rem;
    color: #888;
    line-height: 1.5;
    margin: 0;
  }

  .podcast-section {
    margin-top: 2rem;
  }

  .content-heading {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #222;
    margin: 0 0 1rem;
    font-weight: 400;
  }

  .podcast-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .podcast-link {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #aaa;
    text-decoration: none;
    border-bottom: 1px solid #444;
    padding-bottom: 1px;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .podcast-link:hover,
  .podcast-link:focus-visible {
    color: #fff;
    border-color: #fff;
  }

  .podcast-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
</style>
