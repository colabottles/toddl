---
import PageLayout from "../layouts/PageLayout.astro";

interface Project {
  title: string;
  url: string;
  description: string;
  stack: string[];
  status: "active" | "ongoing" | "stable";
}

const projects: Project[] = [
  {
    title: "ZulkirBot",
    url: "https://zulkirbot-docs.netlify.app",
    description:
      "A full chat RPG bot for my Twitch stream. Duels, campaigns, inventories, guild bonuses, and a barkeep named Nachowench.",
    stack: ["TypeScript", "tmi.js", "Supabase"],
    status: "active",
  },
  {
    title: "DDO Overlay",
    url: "https://github.com/colabottles",
    description:
      "OBS overlay for DDO stream data pulled from the DDO Audit API. Config page, character display, WCAG 2.2 contrast.",
    stack: ["Nuxt 4", "DDO Audit API", "Netlify"],
    status: "active",
  },
  {
    title: "Groovemark",
    url: "https://github.com/colabottles",
    description:
      "A Last.fm alternative and music scrobbler with D3 visualizations and a browser extension for Chrome and Firefox.",
    stack: ["Nuxt 4", "Supabase", "AT Protocol", "D3"],
    status: "ongoing",
  },
  {
    title: "Candlekeep Codex",
    url: "https://github.com/colabottles",
    description:
      "D&D lore reference covering all nine editions. Sanity CMS, D3 force graph, Leaflet map, Pagefind search.",
    stack: ["Astro 6", "Sanity", "D3", "Leaflet"],
    status: "ongoing",
  },
  {
    title: "BranchFlow",
    url: "https://branchflow.netlify.app",
    description:
      "Keyboard-accessible Git history explorer with an SVG commit graph and ARIA live regions.",
    stack: ["Nuxt 4", "GitHub API"],
    status: "stable",
  },
];

const statusLabel: Record<Project["status"], string> = {
  active: "Active",
  ongoing: "In progress",
  stable: "Stable",
};
---

<PageLayout title="Misc — Todd Libby" pageNumber={5} pageLabel="Misc">
  <Fragment slot="main">
    <p class="section-label">Projects & experiments</p>
    <p class="intro-text">
      Things that don't fit neatly anywhere else — side projects, experiments,
      and tools I've built for myself or the stream.
    </p>

    <ul class="project-list" role="list">
      {
        projects.map((project) => (
          <li class="project-item">
            <a
              href={project.url}
              class="project-link"
              rel="noopener noreferrer"
            >
              <div class="project-header">
                <span class="project-title">{project.title}</span>
                <span
                  class={`project-status status--${project.status}`}
                  aria-label={`Status: ${statusLabel[project.status]}`}
                >
                  {statusLabel[project.status]}
                </span>
              </div>
              <p class="project-desc">{project.description}</p>
              <div class="tag-list" aria-label="Stack">
                {project.stack.map((s) => (
                  <span class="tag">{s}</span>
                ))}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Projects</p>
      <p class="stat-num">{projects.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Status key</p>
      <ul class="status-key" aria-label="Project status legend">
        <li>
          <span class="status-dot status--active" aria-hidden="true"></span>
          <span class="side-text">Active — being worked on now</span>
        </li>
        <li>
          <span class="status-dot status--ongoing" aria-hidden="true"></span>
          <span class="side-text">In progress — being built</span>
        </li>
        <li>
          <span class="status-dot status--stable" aria-hidden="true"></span>
          <span class="side-text">Stable — live, not changing</span>
        </li>
      </ul>
    </div>

    <div class="side-item">
      <p class="section-label">GitHub</p>
      <a
        href="https://github.com/colabottles"
        class="side-link"
        rel="noopener noreferrer">colabottles</a
      >
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .project-item {
    border-bottom: 1px solid #222;
  }

  .project-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.15s;
  }

  .project-link:hover {
    padding-left: 0.5rem;
  }

  .project-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-title {
    font-family: "Oswald", sans-serif;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
  }

  .project-status {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 7px;
    border: 1px solid;
    white-space: nowrap;
  }

  .status--active {
    color: #6fcf97;
    border-color: #2d5a3d;
  }

  .status--ongoing {
    color: #f2c94c;
    border-color: #5a4a1a;
  }

  .status--stable {
    color: #888;
    border-color: #333;
  }

  .project-desc {
    font-size: 0.85rem;
    color: #888;
    line-height: 1.6;
  }

  .status-key {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 0.5rem;
  }

  .status-key li {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot.status--active {
    background: #6fcf97;
    border: none;
  }

  .status-dot.status--ongoing {
    background: #f2c94c;
    border: none;
  }

  .status-dot.status--stable {
    background: #555;
    border: none;
  }
</style>
