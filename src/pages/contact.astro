---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Contact — Todd Libby"
  pageNumber={3}
  pageLabel="Contact"
  nextLabel="04 — Links"
  nextHref="/links"
>
  <Fragment slot="main">
    <p class="section-label">Get in touch</p>
    <p class="intro-text">
      Have a project, question, or just want to talk about the web? I'm
      reachable in a few places.
    </p>
    <p class="body-text">
      The best way to reach me is via email or Bluesky. I try to respond within
      a day or two. If it's about an accessibility audit, a speaking engagement,
      or a freelance project, the more detail you can include the better.
    </p>

    <blockquote class="pull-quote">
      <p>"If it's about the web, I probably want to hear it."</p>
    </blockquote>

    <p class="body-text">
      I'm not currently taking on new long-term client projects, but I'm open to
      short engagements, accessibility audits, and consulting work.
    </p>

    <div class="contact-grid" role="list" aria-label="Contact methods">
      <div class="contact-item" role="listitem">
        <p class="contact-label">Email</p>
        <a href="mailto:todd@toddl.dev" class="contact-value">todd@toddl.dev</a>
      </div>
      <div class="contact-item" role="listitem">
        <p class="contact-label">Bluesky</p>
        <a
          href="https://bsky.app/profile/toddl.dev"
          class="contact-value"
          rel="noopener noreferrer">@toddl.dev</a
        >
      </div>
      <div class="contact-item" role="listitem">
        <p class="contact-label">GitHub</p>
        <a
          href="https://github.com/colabottles"
          class="contact-value"
          rel="noopener noreferrer">colabottles</a
        >
      </div>
      <div class="contact-item" role="listitem">
        <p class="contact-label">Twitch</p>
        <a
          href="https://twitch.tv/zulkirjax"
          class="contact-value"
          rel="noopener noreferrer">zulkirjax</a
        >
      </div>
    </div>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Response time</p>
      <p class="side-heading">1–2 days</p>
      <p class="side-text">Usually faster on Bluesky.</p>
    </div>

    <div class="side-item">
      <p class="section-label">Open to</p>
      <div class="tag-list">
        <span class="tag">Audits</span>
        <span class="tag">Consulting</span>
        <span class="tag">Speaking</span>
        <span class="tag">Short projects</span>
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Not open to</p>
      <div class="tag-list">
        <span class="tag tag--dim">Long-term retainers</span>
        <span class="tag tag--dim">Cold sales pitches</span>
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Timezone</p>
      <p class="side-heading">MST / UTC−7</p>
      <p class="side-text">Phoenix, Arizona. No DST.</p>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid #222;
    margin-top: 2rem;
  }

  .contact-item {
    padding: 1.25rem 0;
    border-right: 1px solid #222;
    border-bottom: 1px solid #222;
  }

  .contact-item:nth-child(even) {
    border-right: none;
    padding-left: 1.25rem;
  }

  .contact-item:nth-last-child(-n + 2) {
    border-bottom: none;
  }

  .contact-label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 0.25rem;
  }

  .contact-value {
    font-family: "Oswald", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    transition: color 0.15s;
  }

  .contact-value:hover,
  .contact-value:focus-visible {
    color: #aaa;
  }

  .contact-value:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .tag--dim {
    color: #555;
    border-color: #222;
  }
</style>
