---
import Base from "../layouts/Base.astro";
import { projects } from "../data/content";
---

<Base title="Projects" description="Web projects built by Todd Libby.">
  <section aria-labelledby="projects-heading">
    <h1 id="projects-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> ls ./projects
    </h1>

    <ul class="proj-grid">
      {
        projects.map((p) => (
          <li
            class:list={[
              "proj-card",
              p.featured && "proj-card--featured",
              p.wide && "proj-card--wide",
            ]}
          >
            <article aria-label={p.name}>
              <header class="proj-card__header">
                <h2 class="proj-card__name">{p.name}</h2>
                {p.status && <p class="proj-card__badge">{p.status}</p>}
              </header>
              <p class="proj-card__desc">{p.description}</p>
              <ul class="proj-card__stack" aria-label="Tech stack">
                {p.stack.map((t) => (
                  <li>
                    <span class="proj-tag">{t}</span>
                  </li>
                ))}
              </ul>
              {(p.url || p.repo) && (
                <footer class="proj-card__links">
                  {p.url && (
                    <a
                      href={p.url}
                      class="proj-link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      visit site
                    </a>
                  )}
                  {p.repo && (
                    <a
                      href={p.repo}
                      class="proj-link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      source
                    </a>
                  )}
                </footer>
              )}
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  .proj-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
    list-style: none;
    padding: 0;
  }

  .proj-card {
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-md);
  }

  .proj-card > article {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
  }

  .proj-card--featured {
    border-color: var(--accent-border);
  }

  .proj-card--wide {
    grid-column: 1 / -1;
  }

  .proj-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .proj-card__name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .proj-card__badge {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    background: var(--accent-bg);
    color: var(--accent);
    border: 0.5px solid var(--accent-border);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.375rem;
    flex-shrink: 0;
  }

  .proj-card__desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.55;
    flex: 1;
  }

  .proj-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
  }

  .proj-tag {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    border: 0.5px solid var(--warm-border-md);
    border-radius: 2px;
    padding: 0.0625rem 0.3125rem;
    color: var(--text-secondary);
  }

  .proj-card__links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .proj-link {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .proj-link:hover {
    opacity: 0.75;
  }

  @media (max-width: 560px) {
    .proj-grid {
      grid-template-columns: 1fr;
    }
    .proj-card--wide {
      grid-column: 1;
    }
  }
</style>
