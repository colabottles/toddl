---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const years = [
  ...new Set(posts.map((p) => new Date(p.data.date).getFullYear().toString())),
].sort((a, b) => Number(b) - Number(a));
---

<Base
  title="Blog"
  description="Blog posts by Todd Libby on web development, accessibility, and more."
>
  <section aria-labelledby="blog-heading">
    <h1 id="blog-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> ls ./blog
    </h1>

    {
      years.map((year) => (
        <section class="year-group" aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`} class="year-heading">
            {year}
          </h2>
          <ul class="post-grid">
            {posts
              .filter(
                (p) => new Date(p.data.date).getFullYear().toString() === year,
              )
              .map((post) => (
                <li class="post-card">
                  <a href={`/blog/${post.id}`} class="post-card__link">
                    <h3 class="post-card__title">{post.data.title}</h3>
                    <div class="post-card__meta">
                      <time
                        class="post-card__date"
                        datetime={new Date(post.data.date).toISOString()}
                      >
                        {new Date(post.data.date).toLocaleDateString("en-US", {
                          month: "short",
                          day: "numeric",
                        })}
                      </time>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <ul class="post-card__tags" aria-label="Tags">
                          {post.data.tags.slice(0, 3).map((tag) => (
                            <li class="post-card__tag">{tag}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </a>
                </li>
              ))}
          </ul>
        </section>
      ))
    }
  </section>
</Base>

<style>
  .year-group {
    margin-bottom: 2rem;
  }

  .year-heading {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .post-card {
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition);
  }

  .post-card:has(.post-card__link:hover) {
    border-color: var(--accent-border);
  }

  .post-card__link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    text-decoration: none;
  }

  .post-card__title {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .post-card__link:hover .post-card__title {
    color: var(--accent);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-card__date {
    font-size: 0.625rem;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .post-card__tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .post-card__tag {
    font-size: 0.5625rem;
    color: var(--accent);
    border: 0.5px solid var(--accent-border);
    border-radius: 2px;
    padding: 0.0625rem 0.375rem;
  }

  @media (max-width: 600px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
