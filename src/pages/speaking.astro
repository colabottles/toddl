---

<Base
  title="Speaking"
  description="Conference talks, workshops, and podcast appearances by Todd Libby."
>
  <section aria-labelledby="speaking-heading">
    <h1 id="speaking-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> ls ./speaking
    </h1>

    <section aria-labelledby="talks-heading">
      <h2 id="talks-heading" class="group-heading">past talks</h2>
      <ul class="talks-list">
        {
          talks.map((t) => (
            <li class="talk-item">
              <time class="talk-item__year">{t.year}</time>
              <p class="talk-item__event">{t.event}</p>
              <p class="talk-item__location">{t.location}</p>
              {t.links.length > 0 && (
                <ul class="talk-item__links">
                  {t.links.map((l) => (
                    <li>
                      <a
                        href={l.href}
                        class="talk-link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {l.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="workshops-heading">
      <h2 id="workshops-heading" class="group-heading">workshops</h2>
      <ul class="talks-list">
        {
          workshops.map((w) => (
            <li class="talk-item">
              <time class="talk-item__year">{w.year}</time>
              <p class="talk-item__event">{w.event}</p>
              <p class="talk-item__location">{w.location}</p>
              <p class="talk-item__title">{w.title}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="podcasts-heading">
      <h2 id="podcasts-heading" class="group-heading">podcasts & streams</h2>
      <ul class="talks-list">
        {
          podcasts.map((p) => (
            <li class="talk-item">
              <time class="talk-item__year">{p.date}</time>
              <a
                href={p.href}
                class="talk-item__event talk-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {p.name}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </section>

  <section aria-labelledby="videos-heading">
    <h2 id="videos-heading" class="group-heading">videos</h2>
    <ul class="talks-list">
