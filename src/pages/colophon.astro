---
import PageLayout from "../layouts/PageLayout.astro";

interface ColophonItem {
  label: string;
  value: string;
}

interface ColophonSection {
  heading: string;
  items: ColophonItem[];
}

const sections: ColophonSection[] = [
  {
    heading: "Built with",
    items: [
      { label: "Generator", value: "Astro" },
      { label: "Interactivity", value: "Vue 3 islands where needed" },
      { label: "CSS", value: "Vanilla CSS — no frameworks, no utilities" },
      { label: "Types", value: "TypeScript throughout" },
    ],
  },
  {
    heading: "Deployed to",
    items: [
      { label: "Host", value: "Netlify" },
      { label: "CI/CD", value: "Netlify — auto-deploy from main" },
    ],
  },
  {
    heading: "Typography",
    items: [
      { label: "Display", value: "Oswald" },
      { label: "Condensed", value: "Barlow Condensed" },
      { label: "Body", value: "Barlow" },
    ],
  },
  {
    heading: "Colors",
    items: [
      { label: "Background", value: "#111" },
      { label: "Border", value: "#333" },
      { label: "Text primary", value: "#fff" },
      { label: "Text secondary", value: "#aaa" },
    ],
  },
  {
    heading: "Accessibility",
    items: [
      { label: "Standard", value: "WCAG 2.2 AA" },
      { label: "HTML", value: "Semantic HTML5 throughout" },
      { label: "Screen readers", value: "Tested with NVDA, JAWS, VoiceOver" },
      { label: "Input", value: "Fully keyboard navigable" },
      { label: "Motion", value: "Respects prefers-reduced-motion" },
    ],
  },
  {
    heading: "Design",
    items: [
      {
        label: "Aesthetic",
        value: "Dark editorial — inspired by print magazine layouts",
      },
      { label: "Analytics", value: "None" },
      { label: "Tracking", value: "None" },
      { label: "Ads", value: "None" },
    ],
  },
];
---

<PageLayout
  title="Colophon — Todd Libby"
  pageNumber={5}
  pageLabel="Misc / Colophon"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">How this site is built</p>
    <p class="intro-text">
      Stack, fonts, hosting, and the decisions behind the design.
    </p>

    {
      sections.map((section) => (
        <section
          aria-labelledby={`section-${section.heading.toLowerCase().replace(/\s+/g, "-")}`}
          class="colophon-section"
        >
          <h2
            id={`section-${section.heading.toLowerCase().replace(/\s+/g, "-")}`}
            class="content-heading"
          >
            {section.heading}
          </h2>
          <dl class="colophon-list">
            {section.items.map((item) => (
              <>
                <dt class="col-term">{item.label}</dt>
                <dd class="col-def">{item.value}</dd>
              </>
            ))}
          </dl>
        </section>
      ))
    }
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Generator</p>
      <p class="side-heading">Astro</p>
    </div>

    <div class="side-item">
      <p class="section-label">Host</p>
      <p class="side-heading">Netlify</p>
    </div>

    <div class="side-item">
      <p class="section-label">Fonts</p>
      <div class="tag-list">
        <span class="tag">Oswald</span>
        <span class="tag">Barlow Condensed</span>
        <span class="tag">Barlow</span>
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Source</p>
      <a
        href="https://github.com/colabottles/toddl"
        class="side-link"
        rel="noopener noreferrer"
      >
        colabottles/toddl
      </a>
    </div>

    <div class="side-item">
      <p class="section-label">Back</p>
      <a href="/misc" class="side-link">Misc</a>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .colophon-section {
    margin-bottom: 0;
  }

  .content-heading {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #222;
    margin: 2rem 0 0;
    font-weight: 400;
  }

  .colophon-list {
    display: grid;
    grid-template-columns: 9rem 1fr;
    margin: 0;
  }

  .col-term {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    padding: 0.7rem 0;
    border-bottom: 1px solid #1a1a1a;
  }

  .col-def {
    font-size: 0.85rem;
    color: #ccc;
    line-height: 1.5;
    padding: 0.7rem 0;
    border-bottom: 1px solid #1a1a1a;
    margin: 0;
  }
</style>
