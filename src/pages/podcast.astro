---

<Base
  title="Podcast"
  description="Front End Nerdery Podcast transcripts by season."
>
  <section aria-labelledby="podcast-heading">
    <h1 id="podcast-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> cat ./podcast
    </h1>

    <p class="podcast-intro">
      The <strong>Front End Nerdery Podcast</strong> — conversations with web developers,
      designers, and accessibility advocates. Currently on hiatus. Listen on <a
        href="https://open.spotify.com/show/3oEGCFmMvRHgCBQJpiKBFP"
        class="podcast-link"
        target="_blank"
        rel="noopener noreferrer">Spotify</a
      > or watch on <a
        href="https://www.youtube.com/@frontendnerdery"
        class="podcast-link"
        target="_blank"
        rel="noopener noreferrer">YouTube</a
      >.
    </p>

    {
      seasons.map((s) => (
        <section
          class="season"
          aria-labelledby={`season-${s.season.toLowerCase().replace(" ", "-")}`}
        >
          <h2
            id={`season-${s.season.toLowerCase().replace(" ", "-")}`}
            class="season__heading"
          >
            {s.season}
            <time class="season__date">{s.date}</time>
          </h2>
          <ul class="episode-list">
            {s.episodes.map((ep) => (
              <li class="episode-item">
                <a
                  href={ep.href}
                  class="episode-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {ep.title}
                </a>
                <span class="episode-label">transcript</span>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </section>
</Base>

<style>
  .podcast-intro {
    font-size: 0.875rem;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 2rem;
    padding: 0.875rem 1rem;
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
  }

  .podcast-intro strong {
    color: var(--accent);
    font-weight: 500;
  }

  .podcast-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .podcast-link:hover {
    opacity: 0.8;
  }

  .season {
    margin-bottom: 2rem;
  }

  .season__heading {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .season__date {
    font-size: 0.6875rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .episode-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .episode-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0.875rem;
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
  }

  .episode-item:hover {
    border-color: var(--accent-border);
  }

  .episode-link {
    color: var(--text-primary);
    text-decoration: none;
    flex: 1;
  }

  .episode-link:hover {
    color: var(--accent);
  }

  .episode-label {
    font-size: 0.625rem;
    color: var(--accent);
    border: 0.5px solid var(--accent-border);
    border-radius: 2px;
    padding: 0.125rem 0.375rem;
    flex-shrink: 0;
  }
</style>
