---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Privacy — Todd Libby"
  pageNumber={5}
  pageLabel="Misc / Privacy"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">Privacy policy</p>
    <p class="intro-text">
      This site does not track you. No analytics, no advertising, no third-party
      scripts that follow you around the web.
    </p>

    <section aria-labelledby="stored-heading">
      <h2 id="stored-heading" class="content-heading">What is stored</h2>
      <dl class="privacy-list">
        <div class="privacy-item">
          <dt class="privacy-term">Theme preference</dt>
          <dd class="privacy-def">
            Stored in <code>localStorage</code> on your device. Never sent to a server.
            Clear it any time by clearing your browser storage.
          </dd>
        </div>
      </dl>
    </section>

    <section aria-labelledby="not-stored-heading">
      <h2 id="not-stored-heading" class="content-heading">
        What is not stored
      </h2>
      <ul class="not-stored-list" role="list">
        <li>No cookies</li>
        <li>No analytics</li>
        <li>No advertising trackers</li>
        <li>No fingerprinting</li>
        <li>No personal data collected</li>
        <li>No data sold or shared with third parties</li>
      </ul>
    </section>

    <section aria-labelledby="third-parties-heading">
      <h2 id="third-parties-heading" class="content-heading">Third parties</h2>
      <dl class="privacy-list">
        <div class="privacy-item">
          <dt class="privacy-term">Google Fonts</dt>
          <dd class="privacy-def">
            Fonts are loaded from Google Fonts. Google may log the request. Use
            a browser extension that blocks Google Fonts requests to avoid this.
          </dd>
        </div>
        <div class="privacy-item">
          <dt class="privacy-term">GitHub API</dt>
          <dd class="privacy-def">
            The GitHub panel fetches public data from the GitHub API. No
            credentials or personal data are sent.
          </dd>
        </div>
        <div class="privacy-item">
          <dt class="privacy-term">YouTube</dt>
          <dd class="privacy-def">
            The speaking page links to YouTube videos. YouTube may set cookies
            if you interact with them. Videos use <code
              >youtube-nocookie.com</code
            > where possible.
          </dd>
        </div>
        <div class="privacy-item">
          <dt class="privacy-term">Netlify</dt>
          <dd class="privacy-def">
            This site is hosted on Netlify, who may collect standard server logs
            (IP address, request time, user agent). See{" "}
            <a
              href="https://www.netlify.com/privacy/"
              class="inline-link"
              rel="noopener noreferrer"
            >
              Netlify's privacy policy
            </a>.
          </dd>
        </div>
      </dl>
    </section>

    <section aria-labelledby="contact-heading">
      <h2 id="contact-heading" class="content-heading">Questions</h2>
      <p class="body-text">
        Questions about privacy? <a href="/contact" class="inline-link"
          >Contact me</a
        >.
      </p>
    </section>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Short version</p>
      <p class="side-text">No tracking. No ads. No funny business.</p>
    </div>

    <div class="side-item">
      <p class="section-label">Cookies</p>
      <p class="side-heading">None</p>
    </div>

    <div class="side-item">
      <p class="section-label">Analytics</p>
      <p class="side-heading">None</p>
    </div>

    <div class="side-item">
      <p class="section-label">Last updated</p>
      <p class="side-text">April 2026</p>
    </div>

    <div class="side-item">
      <p class="section-label">Questions</p>
      <a href="/contact" class="side-link">Contact me</a>
    </div>

    <div class="side-item">
      <p class="section-label">Back</p>
      <a href="/misc" class="side-link">Misc</a>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .content-heading {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #222;
    margin: 2rem 0 0;
    font-weight: 400;
  }

  .privacy-list {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .privacy-item {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid #1a1a1a;
    align-items: baseline;
  }

  .privacy-term {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    font-weight: 400;
  }

  .privacy-def {
    font-size: 0.85rem;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
  }

  .privacy-def code {
    font-family: "Courier New", monospace;
    font-size: 0.85em;
    background: #1a1a1a;
    border: 1px solid #333;
    padding: 1px 4px;
    color: #ddd;
  }

  .not-stored-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin-top: 1rem;
  }

  .not-stored-list li {
    font-size: 0.85rem;
    color: #aaa;
    padding: 0.6rem 0;
    border-bottom: 1px solid #1a1a1a;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .not-stored-list li::before {
    content: "";
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #333;
    flex-shrink: 0;
  }

  .inline-link {
    color: #fff;
    text-underline-offset: 3px;
  }

  .inline-link:hover,
  .inline-link:focus-visible {
    text-decoration: none;
  }

  .inline-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
</style>
