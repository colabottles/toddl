---
layout: layouts/page.njk
title: Followers
date: 2026-03-20
permalink: /followers/
---

<style>
  .followers-page {
    --f-purple:       #b07ee0;
    --f-purple-hover: #c9a2f0;
    --f-green:        #5fd97a;
    --f-green-bg:     #0a2414;
    --f-green-border: #2a6640;
    --f-red:          #f4918a;
    --f-red-bg:       #2e1010;
    --f-red-border:   #7a2020;
    --f-text:         #f0ede6;
    --f-text-muted:   #ccc9c0;
    --f-text-subtle:  #a8a59e;
    --f-surface:      #1a2e2a;
    --f-surface-2:    #1e3530;
    --f-border:       #2e4a44;
    --f-radius:       8px;
  }

  .followers-page,
  .followers-page * {
    text-transform: none;
    display: revert;
  }

  .followers-page,
  .followers-page *,
  .followers-page *::before,
  .followers-page *::after {
    box-sizing: border-box;
  }

  .followers-page {
    display: block !important;
    grid-column: 2 / 12;
    color: var(--f-text);
    padding-block: 1rem 4rem;
    font-family: "Inter Tight", sans-serif;
  }

  .followers-page .fp-header {
    display: flex !important;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .followers-page .fp-title {
    font-size: 1.6rem !important;
    font-weight: 700 !important;
    color: var(--f-purple) !important;
    text-transform: none !important;
    flex: 1;
    margin: 0 !important;
    padding: 0 !important;
    line-height: 1.2 !important;
  }

  .followers-page .fp-title span {
    color: var(--f-text-subtle) !important;
    font-weight: 400 !important;
    font-size: 0.9rem !important;
    display: block;
    margin-top: 0.25rem;
  }

  .followers-page .fp-btn {
    display: inline-block !important;
    padding: 0.45rem 1.25rem !important;
    border-radius: 999px !important;
    border: 2px solid var(--f-purple) !important;
    background: transparent !important;
    color: var(--f-purple) !important;
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    font-family: "Inter Tight", sans-serif !important;
    cursor: pointer !important;
    transition: background 0.15s, color 0.15s !important;
    text-decoration: none !important;
    float: none !important;
    width: auto !important;
    margin: 0 !important;
  }

  .followers-page .fp-btn:hover {
    background: var(--f-purple) !important;
    color: #ffffff !important;
  }

  .followers-page .fp-btn:focus-visible {
    outline: 3px solid var(--f-purple) !important;
    outline-offset: 2px !important;
  }

  .followers-page .fp-btn:disabled {
    opacity: 0.5 !important;
    cursor: default !important;
  }

  .followers-page .fp-stats {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)) !important;
    gap: 1rem !important;
    margin-bottom: 1.5rem !important;
  }

  .followers-page .fp-stat {
    display: block !important;
    background: var(--f-surface) !important;
    border: 1px solid var(--f-border) !important;
    border-radius: var(--f-radius) !important;
    padding: 1rem 1.25rem !important;
  }

  .followers-page .fp-stat-label {
    display: block !important;
    font-size: 0.75rem !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    color: var(--f-text-muted) !important;
    margin-bottom: 0.35rem !important;
  }

  .followers-page .fp-stat-value {
    display: block !important;
    font-size: 2rem !important;
    font-weight: 700 !important;
    line-height: 1 !important;
    color: var(--f-text) !important;
  }

  .followers-page .fp-stat.total .fp-stat-value { color: var(--f-purple) !important; }
  .followers-page .fp-stat.new   .fp-stat-value { color: var(--f-green)  !important; }
  .followers-page .fp-stat.lost  .fp-stat-value { color: var(--f-red)    !important; }

  .followers-page .fp-chart-wrap {
    display: block !important;
    background: var(--f-surface) !important;
    border: 1px solid var(--f-border) !important;
    border-radius: var(--f-radius) !important;
    padding: 1.25rem 1.25rem 0.75rem !important;
    margin-bottom: 2rem !important;
  }

  .followers-page .fp-chart-title {
    display: block !important;
    font-size: 0.75rem !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    color: var(--f-text-muted) !important;
    margin: 0 0 0.75rem !important;
    padding: 0 !important;
    border: none !important;
  }

  .followers-page canvas {
    display: block !important;
    width: 100% !important;
    height: 160px !important;
  }

  .followers-page .fp-tabs {
    display: flex !important;
    gap: 0.5rem !important;
    flex-wrap: wrap !important;
    align-items: center !important;
    margin-bottom: 1rem !important;
  }

  .followers-page .fp-tab {
    display: inline-block !important;
    padding: 0.45rem 1rem !important;
    border-radius: 999px !important;
    border: 2px solid var(--f-border) !important;
    background: var(--f-surface) !important;
    color: var(--f-text-muted) !important;
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    font-family: "Inter Tight", sans-serif !important;
    cursor: pointer !important;
    transition: border-color 0.15s, color 0.15s, background 0.15s !important;
    text-decoration: none !important;
    float: none !important;
    width: auto !important;
    margin: 0 !important;
  }

  .followers-page .fp-tab:hover {
    border-color: var(--f-purple) !important;
    color: var(--f-purple) !important;
    background: var(--f-surface) !important;
    text-decoration: none !important;
  }

  .followers-page .fp-tab:focus-visible {
    outline: 3px solid var(--f-purple) !important;
    outline-offset: 2px !important;
  }

  .followers-page .fp-tab.active {
    background: var(--f-purple) !important;
    border-color: var(--f-purple) !important;
    color: #ffffff !important;
  }

  .followers-page .fp-search-wrap { margin-left: auto !important; }

  .followers-page .fp-search {
    display: block !important;
    padding: 0.4rem 0.85rem !important;
    border-radius: 999px !important;
    border-top: 1px solid var(--f-border) !important;
    border-right: 1px solid var(--f-border) !important;
    border-bottom: 2px solid var(--f-purple) !important;
    border-left: 1px solid var(--f-border) !important;
    background: var(--f-surface-2) !important;
    color: var(--f-text) !important;
    font-size: 0.875rem !important;
    font-family: "Inter Tight", sans-serif !important;
    outline: none !important;
    width: 200px !important;
    margin: 0 !important;
  }

  .followers-page .fp-search:focus {
    border-color: var(--f-purple) !important;
    outline: 3px solid var(--f-purple) !important;
    outline-offset: 1px !important;
  }

  .followers-page .fp-snapshot {
    display: block !important;
    font-size: 0.75rem !important;
    font-weight: 600 !important;
    color: var(--f-text-subtle) !important;
  }

  .followers-page .fp-grid {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)) !important;
    gap: 1rem !important;
  }

  .followers-page .fp-card {
    display: flex !important;
    background: var(--f-surface) !important;
    border: 1px solid var(--f-border) !important;
    border-radius: var(--f-radius) !important;
    padding: 1rem !important;
    align-items: center !important;
    gap: 0.75rem !important;
    transition: transform 0.15s !important;
    margin: 0 !important;
  }

  .followers-page .fp-card:hover { transform: translateY(-2px) !important; }
  .followers-page .fp-card.new-follower { border-left: 4px solid var(--f-green) !important; }
  .followers-page .fp-card.unfollower   { border-left: 4px solid var(--f-red)   !important; }

  .followers-page .fp-avatar {
    display: block !important;
    width: 44px !important;
    height: 44px !important;
    min-width: 44px !important;
    border-radius: 50% !important;
    background: var(--f-border) !important;
    object-fit: cover !important;
    filter: none !important;
    border: none !important;
  }

  .followers-page .fp-info { min-width: 0 !important; }

  .followers-page .fp-name {
    display: block !important;
    font-weight: 600 !important;
    font-size: 0.9rem !important;
    color: var(--f-text) !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
  }

  .followers-page .fp-login {
    display: block !important;
    font-size: 0.75rem !important;
    color: var(--f-text-muted) !important;
    text-decoration: none !important;
  }

  .followers-page .fp-when {
    display: block !important;
    font-size: 0.7rem !important;
    color: var(--f-text-subtle) !important;
    margin-top: 0.15rem !important;
  }

  .followers-page .fp-badge {
    display: inline-block !important;
    font-size: 0.65rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.04em !important;
    padding: 0.2rem 0.5rem !important;
    border-radius: 4px !important;
    margin-top: 0.25rem !important;
    border: 1px solid transparent !important;
  }

  .followers-page .fp-badge-new  {
    background: var(--f-green-bg) !important;
    color: var(--f-green) !important;
    border-color: var(--f-green-border) !important;
  }

  .followers-page .fp-badge-lost {
    background: var(--f-red-bg) !important;
    color: var(--f-red) !important;
    border-color: var(--f-red-border) !important;
  }

  .followers-page .fp-status {
    display: block !important;
    margin: 2rem auto !important;
    text-align: center !important;
    color: var(--f-text-muted) !important;
    font-size: 0.9rem !important;
    font-weight: 500 !important;
  }

  .followers-page .fp-error-msg {
    display: block !important;
    background: var(--f-red-bg) !important;
    color: var(--f-red) !important;
    border: 1px solid var(--f-red-border) !important;
    border-radius: var(--f-radius) !important;
    padding: 1rem 1.25rem !important;
    margin-bottom: 1rem !important;
    font-size: 0.9rem !important;
    font-weight: 600 !important;
  }

  @keyframes fp-shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position:  600px 0; }
  }

  .followers-page .fp-skeleton {
    background: linear-gradient(90deg, var(--f-border) 25%, var(--f-surface-2) 50%, var(--f-border) 75%) !important;
    background-size: 600px 100% !important;
    animation: fp-shimmer 1.4s infinite linear !important;
    border-radius: 6px !important;
  }

  .followers-page .fp-skel-card {
    display: flex !important;
    background: var(--f-surface) !important;
    border: 1px solid var(--f-border) !important;
    border-radius: var(--f-radius) !important;
    padding: 1rem !important;
    align-items: center !important;
    gap: 0.75rem !important;
  }

  .followers-page .fp-skel-avatar {
    width: 44px !important;
    height: 44px !important;
    border-radius: 50% !important;
    flex-shrink: 0 !important;
  }

  .followers-page .fp-skel-lines {
    flex: 1 !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 0.4rem !important;
  }

  .followers-page .fp-skel-line   { height: 10px !important; }
  .followers-page .fp-skel-line.short { width: 55% !important; }

  @media (max-width: 540px) {
    .followers-page .fp-grid { grid-template-columns: 1fr !important; }
    .followers-page .fp-title { font-size: 1.3rem !important; }
  }
</style>

<div class="followers-page">

  <header class="fp-header">
    <h1 class="fp-title">
      Twitch Followers
      <span id="fp-updated"></span>
    </h1>
    <button class="fp-btn" id="fp-refresh" onclick="fpLoad()" aria-label="Refresh follower data">Refresh</button>
  </header>

  <div class="fp-stats" role="region" aria-label="Follower statistics">
    <div class="fp-stat total">
      <span class="fp-stat-label" id="fp-lbl-total">Total followers</span>
      <span class="fp-stat-value" id="fp-total" aria-labelledby="fp-lbl-total">—</span>
    </div>
    <div class="fp-stat new">
      <span class="fp-stat-label" id="fp-lbl-new">New since last check</span>
      <span class="fp-stat-value" id="fp-new" aria-labelledby="fp-lbl-new">—</span>
    </div>
    <div class="fp-stat lost">
      <span class="fp-stat-label" id="fp-lbl-lost">Unfollowed since last check</span>
      <span class="fp-stat-value" id="fp-lost" aria-labelledby="fp-lbl-lost">—</span>
    </div>
  </div>

  <div class="fp-chart-wrap" id="fp-chart-wrap" style="display:none" role="region" aria-label="Follower count chart">
    <span class="fp-chart-title">Follower count — last 90 days</span>
    <canvas id="fp-chart" role="img" aria-label="Line chart of follower count over the past 90 days"></canvas>
  </div>

  <div class="fp-tabs" role="tablist" aria-label="Follower views">
    <button class="fp-tab active" role="tab" aria-selected="true"  data-tab="all"  onclick="fpTab('all')">All followers</button>
    <button class="fp-tab"        role="tab" aria-selected="false" data-tab="new"  onclick="fpTab('new')">New</button>
    <button class="fp-tab"        role="tab" aria-selected="false" data-tab="lost" onclick="fpTab('lost')">Unfollowers</button>
    <div class="fp-search-wrap">
      <label for="fp-search" class="sr-only">Search followers</label>
      <input class="fp-search" type="search" id="fp-search" placeholder="Search…" oninput="fpRender()">
    </div>
    <span class="fp-snapshot" id="fp-snapshot" aria-live="polite"></span>
  </div>

  <div id="fp-error" role="alert"></div>
  <div id="fp-grid" class="fp-grid" aria-live="polite" aria-label="Follower list"></div>
  <div class="fp-status" id="fp-status" aria-live="polite"></div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
  const FP_URL = "/.netlify/functions/twitch";
  let fpAll = [], fpNew = [], fpLost = [], fpTab_ = "all", fpChart = null;

  fpLoad();

  async function fpLoad() {
    const btn = document.getElementById("fp-refresh");
    btn.disabled = true;
    btn.textContent = "Loading…";
    fpSetError("");
    fpSkeletons();
    try {
      const res  = await fetch(FP_URL);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Unknown error");

      fpAll  = data.followers  ?? data.data ?? [];
      fpNew  = data.newFollowers ?? [];
      fpLost = data.unfollowers  ?? [];

      document.getElementById("fp-total").textContent =
        (data.totalCount ?? fpAll.length).toLocaleString();
      document.getElementById("fp-new").textContent  = fpNew.length;
      document.getElementById("fp-lost").textContent = fpLost.length;

      if (data.snapshotAge != null)
        document.getElementById("fp-snapshot").textContent =
          `Last snapshot ${data.snapshotAge}m ago`;

      if (data.history && data.history.length > 1) {
        fpDrawChart(data.history);
        document.getElementById("fp-chart-wrap").style.display = "";
      }

      document.getElementById("fp-updated").textContent =
        `Updated ${new Date().toLocaleTimeString([], {hour:"2-digit", minute:"2-digit"})}`;

      fpRender();
    } catch (err) {
      fpSetError("Could not load follower data: " + err.message);
      document.getElementById("fp-grid").innerHTML = "";
      document.getElementById("fp-status").textContent = "";
    } finally {
      btn.disabled = false;
      btn.textContent = "Refresh";
    }
  }

  function fpTab(tab) {
    fpTab_ = tab;
    document.querySelectorAll(".fp-tab").forEach(t => {
      const a = t.dataset.tab === tab;
      t.classList.toggle("active", a);
      t.setAttribute("aria-selected", String(a));
    });
    fpRender();
  }

  function fpRender() {
    const q = (document.getElementById("fp-search").value || "").toLowerCase();
    let list = fpTab_ === "new" ? fpNew : fpTab_ === "lost" ? fpLost : fpAll;
    if (q) list = list.filter(f =>
      (f.user_name || "").toLowerCase().includes(q) ||
      (f.user_login || "").toLowerCase().includes(q)
    );
    const grid = document.getElementById("fp-grid");
    const status = document.getElementById("fp-status");
    if (list.length === 0) {
      grid.innerHTML = "";
      status.textContent =
        q               ? "No results match your search."             :
        fpTab_ === "new"  ? "No new followers since last check."        :
        fpTab_ === "lost" ? "No unfollowers detected since last check." :
                            "No followers yet.";
      return;
    }
    status.textContent = "";
    grid.innerHTML = list.map(fpCard).join("");
  }

  function fpCard(f) {
    const isLost = fpTab_ === "lost";
    const isNew  = fpTab_ === "new" || fpNew.some(n => n.user_id === f.user_id);
    const cls    = "fp-card" + (isLost ? " unfollower" : isNew ? " new-follower" : "");
    const name   = f.user_name || f.display_name || f.user_login || "Unknown";
    const login  = f.user_login || "";
    const avatar = f.profile_image_url
      ? `<img class="fp-avatar" src="${esc(f.profile_image_url)}" alt="${esc(name)}" loading="lazy">`
      : `<div class="fp-avatar" role="img" aria-label="${esc(name)}"></div>`;
    const when = isLost
      ? (f.unfollowed_detected_at ? `<span class="fp-when">Detected ${fpRelTime(f.unfollowed_detected_at)}</span>` : "")
      : (f.followed_at ? `<span class="fp-when">Since ${fpRelTime(f.followed_at)}</span>` : "");
    const badge = isLost ? `<span class="fp-badge fp-badge-lost">Unfollowed</span>`
                : isNew  ? `<span class="fp-badge fp-badge-new">New</span>`
                :          "";
    return `<article class="${cls}" aria-label="${esc(name)}">
      ${avatar}
      <div class="fp-info">
        <span class="fp-name">${esc(name)}</span>
        <span class="fp-login">@${esc(login)}</span>
        ${when}${badge}
      </div>
    </article>`;
  }

  function fpDrawChart(history) {
    const ctx = document.getElementById("fp-chart").getContext("2d");
    if (fpChart) fpChart.destroy();
    fpChart = new Chart(ctx, {
      type: "line",
      data: {
        labels: history.map(h =>
          new Date(h.created_at).toLocaleDateString([], {month:"short", day:"numeric"})
        ),
        datasets: [{
          data: history.map(h => h.count),
          borderColor: "#b07ee0",
          backgroundColor: "rgba(176,126,224,0.1)",
          borderWidth: 2,
          pointRadius: history.length > 30 ? 0 : 3,
          pointHoverRadius: 5,
          fill: true,
          tension: 0.35,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: c => ` ${c.parsed.y.toLocaleString()} followers` } }
        },
        scales: {
          x: { ticks: { color: "#a8a59e", font: { size: 11 }, maxTicksLimit: 10 }, grid: { display: false } },
          y: { ticks: { color: "#a8a59e", font: { size: 11 }, callback: v => v.toLocaleString() }, grid: { color: "rgba(255,255,255,0.06)" } }
        }
      }
    });
  }

  function fpSkeletons() {
    document.getElementById("fp-grid").innerHTML = Array.from({length: 12}, () => `
      <div class="fp-skel-card" aria-hidden="true">
        <div class="fp-skeleton fp-skel-avatar"></div>
        <div class="fp-skel-lines">
          <div class="fp-skeleton fp-skel-line"></div>
          <div class="fp-skeleton fp-skel-line short"></div>
        </div>
      </div>`).join("");
  }

  function fpSetError(msg) {
    document.getElementById("fp-error").innerHTML =
      msg ? `<div class="fp-error-msg">${esc(msg)}</div>` : "";
  }

  function esc(s) {
    return String(s ?? "")
      .replace(/&/g,"&amp;").replace(/</g,"&lt;")
      .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function fpRelTime(iso) {
    const d = Date.now() - new Date(iso).getTime();
    const m = Math.floor(d/60000), h = Math.floor(m/60), dy = Math.floor(h/24);
    if (dy > 1) return `${dy}d ago`;
    if (h  > 0) return `${h}h ago`;
    if (m  > 0) return `${m}m ago`;
    return "just now";
  }
</script>
