---
import PageLayout from "../layouts/PageLayout.astro";

interface Link {
  title: string;
  url: string;
  description: string;
  category: string;
}

// Replace with your actual links or pull from a CMS/content collection
const links: Link[] = [
  {
    title: "scottohara.me",
    url: "https://www.scottohara.me",
    description: "Scott O'Hara's writing on accessibility and ARIA.",
    category: "Accessibility",
  },
  {
    title: "Inclusive Components",
    url: "https://inclusive-components.design",
    description:
      "A pattern library with accessibility baked in, by Heydon Pickering.",
    category: "Accessibility",
  },
  {
    title: "WebAIM Million Report",
    url: "https://webaim.org/projects/million/",
    description: "The annual report on the accessibility of the top 1,000,000 home pages.",
    category: "Accessibility",
  },
  {
    title: "AT Protocol Docs",
    url: "https://atproto.com/docs",
    description: "Official documentation for the AT Protocol powering Bluesky.",
    category: "AT Protocol",
  },
  {
    title: "MDN Web Docs",
    url: "https://developer.mozilla.org",
    description: "The canonical reference for HTML, CSS, and JavaScript.",
    category: "Reference",
  },
  {
    title: "A List Apart",
    url: "https://alistapart.com",
    description: "Long-form writing about web design and development.",
    category: "Web",
  },
];

const categories = [...new Set(links.map((l) => l.category))];
---

<PageLayout
  title="Links — Todd Libby"
  pageNumber={4}
  pageLabel="Links"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">Around the web</p>
    <p class="intro-text">
      A running collection of things I find useful, interesting, or worth coming
      back to.
    </p>

    {
      categories.map((cat) => (
        <section
          class="link-section"
          aria-labelledby={`cat-${cat.toLowerCase().replace(/\s+/g, "-")}`}
        >
          <h2
            id={`cat-${cat.toLowerCase().replace(/\s+/g, "-")}`}
            class="link-category"
          >
            {cat}
          </h2>
          <ul class="link-list" role="list">
            {links
              .filter((l) => l.category === cat)
              .map((link) => (
                <li class="link-item">
                  <a
                    href={link.url}
                    class="link-anchor"
                    rel="noopener noreferrer"
                  >
                    <span class="link-title">{link.title}</span>
                    <span class="link-url" aria-hidden="true">
                      {link.url.replace(/^https?:\/\//, "")}
                    </span>
                    <span class="link-desc">{link.description}</span>
                  </a>
                </li>
              ))}
          </ul>
        </section>
      ))
    }
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Total links</p>
      <p class="stat-num">{links.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Categories</p>
      <div class="tag-list">
        {categories.map((cat) => <span class="tag">{cat}</span>)}
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Updated</p>
      <p class="side-text">Manually curated. No algorithm.</p>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .link-section {
    margin-bottom: 2rem;
  }

  .link-category {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #222;
    margin-bottom: 0;
    font-weight: 400;
  }

  .link-list {
    list-style: none;
  }

  .link-item {
    border-bottom: 1px solid #1a1a1a;
  }

  .link-anchor {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.15s;
  }

  .link-anchor:hover {
    padding-left: 0.5rem;
  }

  .link-anchor:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .link-title {
    font-family: "Oswald", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
  }

  .link-url {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: #444;
  }

  .link-desc {
    font-size: 0.8rem;
    color: #888;
    line-height: 1.5;
  }
</style>
