---
layout: layouts/followers.njk
title: Followers
date: 2026-03-20
permalink: /followers/
---

<header class="page-header">
  <h1>Twitch Followers <span id="updated-note"></span></h1>
  <button class="refresh-btn" id="refresh-btn" onclick="load()">Refresh</button>
</header>

<div class="stats">
  <div class="stat-card total">
    <div class="label">Total followers</div>
    <div class="value" id="stat-total">—</div>
  </div>
  <div class="stat-card new">
    <div class="label">New since last check</div>
    <div class="value" id="stat-new">—</div>
  </div>
  <div class="stat-card lost">
    <div class="label">Unfollowed since last check</div>
    <div class="value" id="stat-lost">—</div>
  </div>
</div>

<div class="chart-wrap" id="chart-wrap" style="display:none">
  <h2>Follower count — last 90 days</h2>
  <canvas id="chart"></canvas>
</div>

<div class="tabs">
  <button class="tab active" data-tab="all"    onclick="switchTab('all')">All followers</button>
  <button class="tab"        data-tab="new"    onclick="switchTab('new')">New</button>
  <button class="tab"        data-tab="lost"   onclick="switchTab('lost')">Unfollowers</button>
  <div class="search-wrap">
    <input type="search" id="search" placeholder="Search…" oninput="render()">
  </div>
  <span class="snapshot-note" id="snapshot-note"></span>
</div>

<div id="error-box"></div>
<div id="grid" class="grid"></div>
<div class="status" id="status"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
  // ── config ──
  // Point this at your Netlify function URL.
  // In production this is relative; in local dev replace with your full Netlify CLI URL.
  const FUNCTION_URL = "/.netlify/functions/twitch";

  // ── state ──
  let allFollowers  = [];
  let newFollowers  = [];
  let unfollowers   = [];
  let activeTab     = "all";
  let chartInstance = null;

  // ── init ──
  load();

  async function load() {
    const btn = document.getElementById("refresh-btn");
    btn.disabled = true;
    btn.textContent = "Loading…";
    setError("");
    showSkeletons();

    try {
      const res  = await fetch(FUNCTION_URL);
      const data = await res.json();

      if (!res.ok) throw new Error(data.error || "Unknown error");

      allFollowers = data.followers  || [];
      newFollowers = data.newFollowers || [];
      unfollowers  = data.unfollowers  || [];

      // Stats
      document.getElementById("stat-total").textContent =
        (data.totalCount ?? allFollowers.length).toLocaleString();
      document.getElementById("stat-new").textContent =
        newFollowers.length;
      document.getElementById("stat-lost").textContent =
        unfollowers.length;

      // Snapshot age note
      if (data.snapshotAge !== null && data.snapshotAge !== undefined) {
        document.getElementById("snapshot-note").textContent =
          `Last snapshot ${data.snapshotAge}m ago`;
      }

      // Chart
      if (data.history && data.history.length > 1) {
        drawChart(data.history);
        document.getElementById("chart-wrap").style.display = "";
      }

      // Updated note
      document.getElementById("updated-note").textContent =
        `— updated ${new Date().toLocaleTimeString([], {hour:"2-digit",minute:"2-digit"})}`;

      render();
    } catch (err) {
      setError("Could not load follower data: " + err.message);
      document.getElementById("grid").innerHTML = "";
      document.getElementById("status").textContent = "";
    } finally {
      btn.disabled = false;
      btn.textContent = "Refresh";
    }
  }

  function switchTab(tab) {
    activeTab = tab;
    document.querySelectorAll(".tab").forEach(t => {
      t.classList.toggle("active", t.dataset.tab === tab);
    });
    render();
  }

  function render() {
    const q = (document.getElementById("search").value || "").toLowerCase();

    let list;
    if      (activeTab === "new")  list = newFollowers;
    else if (activeTab === "lost") list = unfollowers;
    else                           list = allFollowers;

    if (q) {
      list = list.filter(f =>
        (f.user_name || "").toLowerCase().includes(q) ||
        (f.user_login || "").toLowerCase().includes(q)
      );
    }

    const grid   = document.getElementById("grid");
    const status = document.getElementById("status");

    if (list.length === 0) {
      grid.innerHTML = "";
      status.textContent = q
        ? "No results match your search."
        : activeTab === "new"  ? "No new followers since last check."
        : activeTab === "lost" ? "No unfollowers detected since last check."
        : "No followers yet.";
      return;
    }

    status.textContent = "";
    grid.innerHTML = list.map(f => cardHTML(f, activeTab)).join("");
  }

  function cardHTML(f, tab) {
    const isNew  = tab === "new"  || newFollowers.some(n => n.user_id === f.user_id);
    const isLost = tab === "lost";
    const cls    = isLost ? "card unfollower" : isNew ? "card new-follower" : "card";

    const avatar = f.profile_image_url
      ? `<img class="avatar" src="${esc(f.profile_image_url)}" alt="" loading="lazy">`
      : `<div class="avatar"></div>`;

    const when = isLost
      ? (f.unfollowed_detected_at
          ? `<div class="followed-at">Detected ${relTime(f.unfollowed_detected_at)}</div>`
          : "")
      : (f.followed_at
          ? `<div class="followed-at">Since ${relTime(f.followed_at)}</div>`
          : "");

    const badge = isLost
      ? `<span class="badge badge-lost">Unfollowed</span>`
      : isNew
        ? `<span class="badge badge-new">New</span>`
        : "";

    return `<div class="${cls}">
      ${avatar}
      <div class="card-info">
        <div class="display-name">${esc(f.user_name || f.display_name || f.user_login)}</div>
        <div class="login">@${esc(f.user_login)}</div>
        ${when}
        ${badge}
      </div>
    </div>`;
  }

  function drawChart(history) {
    const ctx = document.getElementById("chart").getContext("2d");
    if (chartInstance) chartInstance.destroy();

    const dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const labels = history.map(h =>
      new Date(h.created_at).toLocaleDateString([], {month:"short", day:"numeric"})
    );
    const values = history.map(h => h.count);

    chartInstance = new Chart(ctx, {
      type: "line",
      data: {
        labels,
        datasets: [{
          data: values,
          borderColor: "#6626af",
          backgroundColor: "rgba(102,38,175,0.08)",
          borderWidth: 2,
          pointRadius: values.length > 30 ? 0 : 3,
          pointHoverRadius: 5,
          fill: true,
          tension: 0.35,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ` ${ctx.parsed.y.toLocaleString()} followers`
            }
          }
        },
        scales: {
          x: {
            ticks: {
              color: dark ? "#9c9a92" : "#5f5e5a",
              font: { size: 11 },
              maxTicksLimit: 10,
            },
            grid: { display: false },
          },
          y: {
            ticks: {
              color: dark ? "#9c9a92" : "#5f5e5a",
              font: { size: 11 },
              callback: v => v.toLocaleString(),
            },
            grid: { color: dark ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.06)" },
          }
        }
      }
    });
  }

  function showSkeletons() {
    document.getElementById("grid").innerHTML = Array.from({length: 12}, () => `
      <div class="skel-card">
        <div class="skeleton skel-avatar"></div>
        <div class="skel-lines">
          <div class="skeleton skel-line"></div>
          <div class="skeleton skel-line short"></div>
        </div>
      </div>
    `).join("");
  }

  function setError(msg) {
    const box = document.getElementById("error-box");
    box.innerHTML = msg ? `<div class="error-msg">${esc(msg)}</div>` : "";
  }

  function esc(str) {
    return String(str ?? "")
      .replace(/&/g,"&amp;").replace(/</g,"&lt;")
      .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function relTime(iso) {
    const diff  = Date.now() - new Date(iso).getTime();
    const mins  = Math.floor(diff / 60000);
    const hours = Math.floor(mins / 60);
    const days  = Math.floor(hours / 24);
    if (days  > 1)  return `${days}d ago`;
    if (hours > 0)  return `${hours}h ago`;
    if (mins  > 0)  return `${mins}m ago`;
    return "just now";
  }
</script>

</body>
</html>
