---
import Base from "../layouts/Base.astro";

const writing = [
  {
    year: "2021",
    title: "Making A Strong Case For Accessibility",
    tag: "article",
    publication: "Smashing Magazine",
    url: "https://www.smashingmagazine.com/2021/07/strong-case-for-accessibility/",
  },
  {
    year: "2021",
    title: "Looking at WCAG 2.5.5 for Better Target Sizes",
    tag: "article",
    publication: "CSS-Tricks",
    url: "https://css-tricks.com/looking-at-wcag-2-5-5-for-better-target-sizes/",
  },
  {
    year: "2020",
    title: "What's New in WCAG 2.1: Label in Name",
    tag: "article",
    publication: "CSS-Tricks",
    url: "https://css-tricks.com/whats-new-in-wcag-2-1-label-in-name/",
  },
];

const books = [
  {
    year: "2024",
    title: "The Web Accessibility Handbook",
    tag: "book",
    url: undefined,
  },
  {
    year: "2023",
    title: "Why hiring in tech is broken",
    tag: "book",
    url: undefined,
  },
];
---

<Base
  title="Writing"
  description="Books and articles by Todd Libby on web accessibility and the tech industry."
>
  <section aria-labelledby="writing-heading">
    <h1 id="writing-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> cat ./writing
    </h1>

    <section aria-labelledby="books-heading">
      <h2 id="books-heading" class="group-heading">books</h2>
      <ul class="writing-list">
        {
          books.map((w) => (
            <li class="writing-item">
              <time class="writing-item__date">{w.year}</time>
              <p class="writing-item__title">{w.title}</p>
              <span class="writing-item__tag">{w.tag}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="articles-heading">
      <h2 id="articles-heading" class="group-heading">articles</h2>
      <ul class="writing-list">
        {
          writing.map((w) => (
            <li class="writing-item">
              <time class="writing-item__date">{w.year}</time>
              <a
                href={w.url}
                class="writing-item__title writing-item__title--link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {w.title}
              </a>
              <span class="writing-item__pub">{w.publication}</span>
              <span class="writing-item__tag">{w.tag}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </section>
</Base>

<style>
  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .writing-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    background: var(--warm-mid);
    flex-wrap: wrap;
  }

  .writing-item__date {
    color: var(--text-secondary);
    min-width: 3.5rem;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .writing-item__title {
    color: var(--text-primary);
    flex: 1;
    text-decoration: none;
  }

  .writing-item__title--link {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .writing-item__title--link:hover {
    color: var(--accent);
  }

  .writing-item__pub {
    font-size: 0.6875rem;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .writing-item__tag {
    font-size: 0.625rem;
    border: 0.5px solid var(--accent-border);
    border-radius: 2px;
    padding: 0.125rem 0.375rem;
    color: var(--accent);
    flex-shrink: 0;
  }
</style>
