---
import PageLayout from "../layouts/PageLayout.astro";

interface Project {
  title: string;
  description: string;
  stack: string[];
  status: "live" | "in progress" | "retired";
  url?: string;
  source?: string;
}

const projects: Project[] = [
  {
    title: "ZulkirBot",
    description:
      "Fully featured Twitch chat RPG bot with two bot accounts, combat system, spellbook, rogue skills, and D&D mechanics built around Dungeons & Dragons Online.",
    stack: ["Node", "TypeScript", "Supabase", "tmi.js", "DDO"],
    status: "live",
  },
  {
    title: "BranchFlow",
    description:
      "Keyboard-accessible Git history explorer with SVG commit graph, ARIA live regions, and light, dark, and high-contrast modes.",
    stack: [
      "Nuxt 4",
      "TypeScript",
      "GitHub API",
      "SVG",
      "Vanilla CSS",
      "Netlify",
    ],
    status: "live",
    url: "https://branchflow.netlify.app",
  },
  {
    title: "BasketBuddy",
    description:
      "Grocery budgeting PWA with Stripe subscriptions, category management, and mobile-first UI.",
    stack: ["Nuxt 4", "Supabase", "Stripe", "PWA", "pnpm"],
    status: "live",
    url: "https://basketbuddyapp.netlify.app",
  },
  {
    title: "Blurcle",
    description:
      "Bluesky analytics — engagement metrics, activity charts, and repost filtering.",
    stack: ["Nuxt 4", "Bluesky API", "npm"],
    status: "live",
    url: "https://blurcle.netlify.app",
    source: "https://github.com/colabottles/blurcle",
  },
  {
    title: "ddo-overlay",
    description:
      "OBS browser source overlay pulling live character data from the DDO Audit API via URL query params.",
    stack: ["TypeScript", "DDO Audit API", "Netlify"],
    status: "live",
    url: "https://ddooverlay.netlify.app",
  },
  {
    title: "RouteReady",
    description:
      "Route management SaaS for tracking drivers, vehicles, and properties.",
    stack: ["Nuxt 4", "Supabase", "PostgreSQL", "Better Auth", "Netlify"],
    status: "in progress",
  },
  {
    title: "Chirp",
    description:
      "Twitter-style social platform with full auth, follow system, RLS, and accessibility preferences.",
    stack: ["Nuxt 4", "Supabase", "RLS", "TypeScript"],
    status: "in progress",
  },
  {
    title: "Broadcast",
    description:
      "Multi-platform social posting — Bluesky, Mastodon, and LinkedIn from one place.",
    stack: ["Nuxt 4", "Supabase", "OAuth", "Bluesky API"],
    status: "retired",
    source: "https://github.com/colabottles/broadcast",
  },
];

const statusLabel: Record<Project["status"], string> = {
  live: "Live",
  "in progress": "In progress",
  retired: "Retired",
};
---

<PageLayout
  title="Projects — Todd Libby"
  pageNumber={5}
  pageLabel="Misc / Projects"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">Built things</p>
    <p class="intro-text">
      Side projects, portfolio work, and tools I've built — some for clients,
      some for the stream, most for myself.
    </p>

    <ul class="project-list" role="list">
      {
        projects.map((project) => (
          <li class="project-item">
            <div class="project-header">
              <span class="project-title">{project.title}</span>
              <span
                class={`project-status status--${project.status.replace(" ", "-")}`}
                aria-label={`Status: ${statusLabel[project.status]}`}
              >
                {statusLabel[project.status]}
              </span>
            </div>
            <p class="project-desc">{project.description}</p>
            <div class="project-footer">
              <div class="tag-list" aria-label="Stack">
                {project.stack.map((s) => (
                  <span class="tag">{s}</span>
                ))}
              </div>
              <div class="project-links">
                {project.url && (
                  <a
                    href={project.url}
                    class="project-link"
                    rel="noopener noreferrer"
                  >
                    Visit site
                  </a>
                )}
                {project.source && (
                  <a
                    href={project.source}
                    class="project-link"
                    rel="noopener noreferrer"
                  >
                    Source
                  </a>
                )}
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Total projects</p>
      <p class="stat-num">{projects.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Status key</p>
      <ul class="status-key" aria-label="Project status legend">
        <li>
          <span class="status-dot dot--live" aria-hidden="true"></span>
          <span class="side-text">Live — deployed and running</span>
        </li>
        <li>
          <span class="status-dot dot--in-progress" aria-hidden="true"></span>
          <span class="side-text">In progress — actively building</span>
        </li>
        <li>
          <span class="status-dot dot--retired" aria-hidden="true"></span>
          <span class="side-text">Retired — archived or sunset</span>
        </li>
      </ul>
    </div>

    <div class="side-item">
      <p class="section-label">GitHub</p>
      <a
        href="https://github.com/colabottles"
        class="side-link"
        rel="noopener noreferrer"
      >
        colabottles
      </a>
    </div>

    <div class="side-item">
      <p class="section-label">Back</p>
      <a href="/misc" class="side-link">Misc</a>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .project-item {
    border-bottom: 1px solid #222;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-title {
    font-family: "Oswald", sans-serif;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
  }

  .project-status {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 7px;
    border: 1px solid;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status--live {
    color: #6fcf97;
    border-color: #2d5a3d;
  }

  .status--in-progress {
    color: #f2c94c;
    border-color: #5a4a1a;
  }

  .status--retired {
    color: #666;
    border-color: #333;
  }

  .project-desc {
    font-size: 0.85rem;
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  .project-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  .project-link {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #aaa;
    text-decoration: none;
    border-bottom: 1px solid #444;
    padding-bottom: 1px;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .project-link:hover,
  .project-link:focus-visible {
    color: #fff;
    border-color: #fff;
  }

  .project-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .status-key {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 0.4rem;
  }

  .status-key li {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot--live {
    background: #6fcf97;
  }
  .dot--in-progress {
    background: #f2c94c;
  }
  .dot--retired {
    background: #444;
  }
</style>
