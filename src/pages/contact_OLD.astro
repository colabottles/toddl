---
import Base from "../layouts/Base.astro";

const links = [
  { label: "web", value: "toddl.dev", href: "https://toddl.dev" },
  {
    label: "github",
    value: "colabottles",
    href: "https://github.com/colabottles",
  },
  {
    label: "bluesky",
    value: "@toddl.dev",
    href: "https://bsky.app/profile/toddl.dev",
  },
  { label: "twitch", value: "toddcodes", href: "https://twitch.tv/toddcodes" },
  {
    label: "mastodon",
    value: "@toddlibby",
    href: "https://notacult.social/@colabottles",
  },
];
---

<Base title="Contact" description="Get in touch with Todd Libby.">
  <section aria-labelledby="contact-heading">
    <h1 id="contact-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> ./contact
    </h1>

    <ul class="contact-list">
      {
        links.map((l) => (
          <li class="contact-item">
            <p class="contact-item__label">{l.label}</p>
            {l.href ? (
              <a
                href={l.href}
                class="contact-item__value"
                target={l.href.startsWith("mailto") ? undefined : "_blank"}
                rel={
                  l.href.startsWith("mailto")
                    ? undefined
                    : "noopener noreferrer"
                }
              >
                {l.value}
              </a>
            ) : (
              <span class="contact-item__value contact-item__value--plain">
                {l.value}
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .contact-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.625rem 0.875rem;
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    background: var(--warm-mid);
    font-size: 0.875rem;
  }

  .contact-item__label {
    color: var(--accent);
    min-width: 5rem;
    flex-shrink: 0;
    font-size: 0.8125rem;
  }

  .contact-item__value {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-item__value:hover {
    color: var(--accent);
  }
</style>
