---
import Base from "../layouts/Base.astro";

const links = [
  {
    category: "podcast",
    items: [
      {
        name: "Front End Nerdery Podcast",
        note: "on hiatus",
        links: [
          {
            label: "Spotify",
            href: "https://open.spotify.com/show/3oEGCFmMvRHgCBQJpiKBFP",
          },
          {
            label: "YouTube",
            href: "https://www.youtube.com/@frontendnerdery",
          },
          { label: "Transcripts", href: "/podcast" },
        ],
      },
    ],
  },
];
---

<Base
  title="Elsewhere"
  description="Other places you can find Todd Libby online."
>
  <section aria-labelledby="elsewhere-heading">
    <h1 id="elsewhere-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> ls ./elsewhere
    </h1>

    <dl class="elsewhere-list">
      {
        links.map((group) => (
          <div class="elsewhere-group">
            <dt class="elsewhere-group__label">{group.category}</dt>
            <dd class="elsewhere-group__items">
              {group.items.map((item) => (
                <article class="elsewhere-item">
                  <header class="elsewhere-item__header">
                    <h2 class="elsewhere-item__name">{item.name}</h2>
                    {item.note && (
                      <p class="elsewhere-item__note">{item.note}</p>
                    )}
                  </header>
                  <ul class="elsewhere-item__links">
                    {item.links.map((l) => (
                      <li>
                        <a
                          href={l.href}
                          class="elsewhere-link"
                          target={l.href.startsWith("/") ? undefined : "_blank"}
                          rel={
                            l.href.startsWith("/")
                              ? undefined
                              : "noopener noreferrer"
                          }
                        >
                          {l.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</Base>

<style>
  .elsewhere-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elsewhere-group {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.75rem;
    padding: 0.75rem 0.875rem;
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    background: var(--warm-mid);
    align-items: start;
  }

  .elsewhere-group__label {
    font-size: 0.75rem;
    color: var(--accent);
    padding-top: 0.125rem;
  }

  .elsewhere-group__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elsewhere-item__header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .elsewhere-item__name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .elsewhere-item__note {
    font-size: 0.6875rem;
    color: var(--text-secondary);
  }

  .elsewhere-item__note::before {
    content: "// ";
    color: var(--accent);
    opacity: 0.6;
  }

  .elsewhere-item__links {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 0.75rem;
  }

  .elsewhere-link {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .elsewhere-link:hover {
    opacity: 0.8;
  }
</style>
