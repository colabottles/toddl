---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="About — Todd Libby"
  pageNumber={1}
  pageLabel="About"
  nextLabel="02 — Blog"
  nextHref="/blog"
>
  <Fragment slot="main">
    <p class="section-label">Introduction</p>
    <p class="intro-text">
      Web developer and accessibility advocate based in Phoenix, Arizona. I
      build things for the web that work for everyone — not just most people.
    </p>
    <p class="body-text">
      I've been working on the web for over two decades, writing HTML, CSS, and
      JavaScript long before frameworks were a thing. These days my stack is
      Nuxt, Astro, Supabase, and vanilla CSS — because I still believe the
      platform is powerful enough on its own.
    </p>
    <p class="body-text">
      Accessibility isn't a checklist I hand off at the end of a project. It's
      how I think from the first line of markup. WCAG 2.2, semantic HTML, and
      honest contrast ratios are non-negotiable starting points.
    </p>

    <blockquote class="pull-quote">
      <p>"The web is for everyone. I'm here to make sure it stays that way."</p>
    </blockquote>

    <p class="body-text">
      When I'm not writing code, I'm streaming DDO on Twitch, tending to
      ZulkirBot, or writing about the web at toddl.dev.
    </p>

    <div class="stat-row">
      <div class="stat-item">
        <p class="stat-num">20+</p>
        <p class="stat-label">Years on the web</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">74</p>
        <p class="stat-label">Posts published</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">AAA</p>
        <p class="stat-label">Contrast target</p>
      </div>
    </div>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Location</p>
      <p class="side-heading">Phoenix, Arizona</p>
      <p class="side-text">Originally from Portland, Maine.</p>
    </div>

    <div class="side-item">
      <p class="section-label">Current stack</p>
      <div class="tag-list">
        <span class="tag">Astro</span>
        <span class="tag">Nuxt 4</span>
        <span class="tag">TypeScript</span>
        <span class="tag">Supabase</span>
        <span class="tag">Vanilla CSS</span>
        <span class="tag">Netlify</span>
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Elsewhere</p>
      <p class="side-heading">@toddl.dev</p>
      <ul class="side-list" aria-label="Social links">
        <li>
          <a
            href="https://bsky.app/profile/toddl.dev"
            class="side-link"
            rel="noopener noreferrer">Bluesky</a>
        </li>
        <li>
          <a
            href="https://github.com/colabottles"
            class="side-link"
            rel="noopener noreferrer">GitHub</a>
        </li>
        <li>
          <a
            href="https://twitch.tv/zulkirjax"
            class="side-link"
            rel="noopener noreferrer">Twitch</a>
        </li>
      </ul>
    </div>

    <div class="side-item">
      <p class="section-label">Interests</p>
      <div class="tag-list">
        <span class="tag">Accessibility</span>
        <span class="tag">Web standards</span>
        <span class="tag">AT Protocol</span>
        <span class="tag">D&amp;D</span>
        <span class="tag">Twitch</span>
      </div>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .side-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 0.4rem;
  }
</style>
