---

<PageLayout
  title="Speaking — Todd Libby"
  pageNumber={5}
  pageLabel="Misc / Speaking"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">Past talks</p>
    <p class="intro-text">
      Conference talks, workshops, and podcast appearances from 2019 through
      2025.
    </p>

    <section aria-labelledby="talks-heading">
      <h2 id="talks-heading" class="content-heading">Conferences</h2>
      <ul class="talk-list" role="list">
        {
          talks.map((talk) => (
            <li class="talk-item">
              <span class="talk-year">{talk.year}</span>
              <div class="talk-body">
                <span class="talk-event">{talk.event}</span>
                <span class="talk-location">{talk.location}</span>
              </div>
              <div class="talk-links">
                {talk.slides && (
                  <a
                    href={talk.slides}
                    class="talk-link"
                    rel="noopener noreferrer"
                  >
                    Slides
                  </a>
                )}
                {talk.slides2 && (
                  <a
                    href={talk.slides2}
                    class="talk-link"
                    rel="noopener noreferrer"
                  >
                    {talk.slides2Label ?? "Slides 2"}
                  </a>
                )}
                {talk.video && (
                  <a
                    href={talk.video}
                    class="talk-link"
                    rel="noopener noreferrer"
                  >
                    Video
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="workshops-heading">
      <h2 id="workshops-heading" class="content-heading">Workshops</h2>
      <ul class="talk-list" role="list">
        {
          workshops.map((w) => (
            <li class="talk-item">
              <span class="talk-year">{w.year}</span>
              <div class="talk-body">
                <span class="talk-event">{w.event}</span>
                <span class="talk-location">{w.location}</span>
                <span class="talk-workshop-title">{w.title}</span>
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="podcasts-heading">
      <h2 id="podcasts-heading" class="content-heading">Podcasts & Streams</h2>
      <ul class="podcast-list" role="list">
        {
          podcasts.map((p) => (
            <li class="podcast-item">
              <span class="talk-year">{p.date}</span>
              <a href={p.url} class="podcast-title" rel="noopener noreferrer">
                {p.title}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Conferences</p>
      <p class="stat-num">{talks.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Workshops</p>
      <p class="stat-num">{workshops.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Podcasts & streams</p>
      <p class="stat-num">{podcasts.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Years active</p>
      <div class="tag-list">
        {years.map((y) => <span class="tag">{y}</span>)}
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Slides on</p>
      <a
        href="https://noti.st/colabottles"
        class="side-link"
        rel="noopener noreferrer"
      >
        noti.st/colabottles
      </a>
    </div>

    <div class="side-item">
      <p class="section-label">Back</p>
      <a href="/misc" class="side-link">Misc</a>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .content-heading {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #222;
    margin: 2rem 0 0;
    font-weight: 400;
  }

  .talk-list,
  .podcast-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin-bottom: 0;
  }

  .talk-item {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid #1a1a1a;
    align-items: start;
  }

  .talk-year {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: #555;
    padding-top: 2px;
  }

  .talk-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .talk-event {
    font-family: "Oswald", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
  }

  .talk-location {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: #555;
  }

  .talk-workshop-title {
    font-size: 0.8rem;
    color: #888;
    margin-top: 2px;
  }

  .talk-links {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-end;
  }

  .talk-link {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
    text-decoration: none;
    border-bottom: 1px solid #333;
    padding-bottom: 1px;
    white-space: nowrap;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .talk-link:hover,
  .talk-link:focus-visible {
    color: #fff;
    border-color: #fff;
  }

  .talk-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .podcast-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #1a1a1a;
    align-items: baseline;
  }

  .podcast-title {
    font-size: 0.85rem;
    color: #ccc;
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.15s;
  }

  .podcast-title:hover,
  .podcast-title:focus-visible {
    color: #fff;
  }

  .podcast-title:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
</style>
