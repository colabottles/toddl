---
import PageLayout from "../layouts/PageLayout.astro";

interface UsesItem {
  name: string;
  note?: string;
}

interface UsesCategory {
  label: string;
  items: UsesItem[];
}

const categories: UsesCategory[] = [
  {
    label: "Editor",
    items: [
      { name: "VS Code", note: "Primary" },
      { name: "Vim", note: "Quick edits" },
    ],
  },
  {
    label: "Terminal",
    items: [{ name: "Ghostty" }, { name: "zsh + oh-my-zsh" }],
  },
  {
    label: "Stack",
    items: [
      { name: "Nuxt 4", note: "All projects" },
      { name: "Supabase", note: "Auth + DB" },
      { name: "Netlify", note: "Deployment" },
      { name: "TypeScript", note: "Always" },
    ],
  },
  {
    label: "Accessibility tools",
    items: [
      { name: "Axe DevTools" },
      { name: "ARC Toolkit" },
      { name: "IBM Equal Access Checker" },
      { name: "NVDA", note: "Screen reader testing" },
      { name: "VoiceOver", note: "Screen reader testing" },
    ],
  },
  {
    label: "Design & misc",
    items: [{ name: "Affinity Photo" }, { name: "CodePen" }],
  },
  {
    label: "Hardware",
    items: [
      { name: "PC", note: "Primary machine" },
      { name: "MacBook Pro 2019", note: "Still tickin'" },
    ],
  },
];
---

<PageLayout
  title="Uses — Todd Libby"
  pageNumber={5}
  pageLabel="Misc / Uses"
  nextLabel="05 — Misc"
  nextHref="/misc"
>
  <Fragment slot="main">
    <p class="section-label">Tools & setup</p>
    <p class="intro-text">
      The hardware, software, and tools I use day to day for development,
      accessibility testing, and streaming.
    </p>

    {
      categories.map((cat) => (
        <section
          aria-labelledby={`cat-${cat.label.toLowerCase().replace(/\s+&?\s*/g, "-")}`}
          class="uses-section"
        >
          <h2
            id={`cat-${cat.label.toLowerCase().replace(/\s+&?\s*/g, "-")}`}
            class="content-heading"
          >
            {cat.label}
          </h2>
          <ul class="uses-list" role="list">
            {cat.items.map((item) => (
              <li class="uses-item">
                <span class="uses-name">{item.name}</span>
                {item.note && <span class="uses-note">{item.note}</span>}
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Primary editor</p>
      <p class="side-heading">VS Code</p>
    </div>

    <div class="side-item">
      <p class="section-label">Terminal</p>
      <p class="side-heading">Ghostty</p>
    </div>

    <div class="side-item">
      <p class="section-label">OS</p>
      <div class="tag-list">
        <span class="tag">Windows (primary)</span>
        <span class="tag">macOS</span>
      </div>
    </div>

    <div class="side-item">
      <p class="section-label">Node</p>
      <p class="side-heading">v22</p>
      <p class="side-text">Required on all projects.</p>
    </div>

    <div class="side-item">
      <p class="section-label">Back</p>
      <a href="/misc" class="side-link">Misc</a>
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .uses-section {
    margin-bottom: 0;
  }

  .content-heading {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #222;
    margin: 2rem 0 0;
    font-weight: 400;
  }

  .uses-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .uses-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #1a1a1a;
  }

  .uses-name {
    font-family: "Oswald", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
  }

  .uses-note {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: #555;
    text-transform: uppercase;
    white-space: nowrap;
  }
</style>
