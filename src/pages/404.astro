---
import Base from '../layouts/Base.astro'
---

<Base title="404" description="Page not found.">
  <section aria-labelledby="error-heading">
    <div class="section-header">
      <span class="section-header__cmd" aria-hidden="true">$</span>
      <span class="section-header__title" aria-hidden="true">whoami</span>
    </div>

    <div class="error-block">
      <p class="error-code" aria-hidden="true">404</p>
      <h1 id="error-heading" class="error-msg">page not found</h1>
      <p class="error-hint">
        <span class="error-prefix" aria-hidden="true">// </span>
        <a href="/" class="error-link">cd ~/home</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .error-block {
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .error-code {
    font-size: 3rem;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
  }

  .error-msg {
    font-size: 0.875rem;
    color: var(--dark);
    font-weight: 400;
  }

  .error-hint {
    font-size: 0.75rem;
    margin-top: 0.5rem;
  }

  .error-prefix {
    color: var(--accent);
    opacity: 0.6;
  }

  .error-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .error-link:hover {
    opacity: 0.75;
  }
</style>
