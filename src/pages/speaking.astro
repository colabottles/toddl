<style>
  .talks-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
  }

  .talk-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    background: var(--warm-mid);
    flex-wrap: wrap;
    font-size: 0.875rem;
  }

  .talk-item__year {
    font-size: 0.75rem;
    color: var(--text-secondary);
    min-width: 3rem;
    flex-shrink: 0;
  }

  .talk-item__event {
    font-weight: 500;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .talk-item__location {
    font-size: 0.75rem;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .talk-item__title {
    font-size: 0.75rem;
    color: var(--text-secondary);
    width: 100%;
  }

  .talk-item__links {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .talk-link {
    font-size: 0.75rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .talk-link:hover {
    opacity: 0.8;
  }
</style>
