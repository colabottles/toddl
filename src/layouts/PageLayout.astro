---
interface Props {
  title: string;
  pageNumber: number;
  pageLabel: string;
  totalPages?: number;
  nextLabel?: string;
  nextHref?: string;
  description?: string;
  standardSiteUri?: string;
  slug?: string;
}

const {
  title,
  pageNumber,
  pageLabel,
  totalPages = 5,
  nextLabel,
  nextHref,
  description,
  standardSiteUri,
  slug,
} = Astro.props;

const PUBLICATION_AT_URI =
  "at://did:plc:gevyqibw5p2xsonkbsbjm5vy/site.standard.publication/3mnqgth7gxo2f";

const canonicalUrl = new URL(
  Astro.url.pathname,
  "https://toddl.dev",
).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://toddl.dev" />
    <meta property="og:title" content="Todd Libby" />
    <meta
      property="og:description"
      content="Former web developer and accessibility advocate based in Phoenix, Arizona."
    />
    <meta
      property="og:image"
      content={slug
        ? `https://toddl.dev/og/${slug}.png`
        : "https://toddl.dev/og-image.png"}
    />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- Standard.site publication registration -->
    <link rel="site.standard.publication" href={PUBLICATION_AT_URI} />

    <!-- Standard.site document registration (blog posts only) -->
    {
      standardSiteUri && (
        <link rel="site.standard.document" href={standardSiteUri} />
      )
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Barlow+Condensed:wght@400;600&family=Barlow:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="page-header">
      <nav class="breadcrumb" aria-label="Site navigation">
        <a href="/" class="back-link" aria-label="Back to home">
          <span aria-hidden="true">&#8592;</span> Home
        </a>
      </nav>
      <div class="header-body">
        <div class="header-text">
          <p class="page-label">
            {String(pageNumber).padStart(2, "0")} &mdash; {pageLabel}
          </p>
          <h1 class="page-title">{title}</h1>
        </div>
        <div class="page-number" aria-hidden="true">{pageNumber}</div>
      </div>
    </header>

    <div class="page-body">
      <main id="main-content" class="col-main">
        <slot name="main" />
      </main>
      <aside class="col-side" aria-label="Page details">
        <slot name="aside" />
      </aside>
    </div>

    <footer class="page-footer">
      <div class="footer-col">
        {
          nextLabel && nextHref ? (
            <>
              <p class="footer-label">Next</p>
              <a href={nextHref} class="footer-value footer-link">
                {nextLabel}
              </a>
            </>
          ) : (
            <>
              <p class="footer-label">End</p>
              <p class="footer-value">&mdash;</p>
            </>
          )
        }
      </div>
      <div class="footer-col">
        <p class="footer-label">Site</p>
        <a href="/" class="footer-value footer-link">toddl.dev</a>
      </div>
      <div class="footer-col">
        <p class="footer-label">Page</p>
        <p class="footer-value">
          {String(pageNumber).padStart(2, "0")} of {
            String(totalPages).padStart(2, "0")
          }
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #111;
    --color-surface: #1a1a1a;
    --color-border: #333;
    --color-border-subtle: #222;
    --color-text-primary: #fff;
    --color-text-secondary: #aaa;
    --color-text-muted: #666;
    --color-text-faint: #444;
    --font-display: "Oswald", sans-serif;
    --font-condensed: "Barlow Condensed", sans-serif;
    --font-body: "Barlow", sans-serif;
  }

  html {
    background: var(--color-bg);
    color: var(--color-text-primary);
    font-family: var(--font-body);
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* Skip link */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: #fff;
    color: #111;
    padding: 0.5rem 1rem;
    font-family: var(--font-condensed);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    z-index: 100;
  }

  .skip-link:focus {
    top: 1rem;
  }

  /* Header */
  .page-header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 2rem 0;
  }

  .breadcrumb {
    margin-bottom: 1.5rem;
  }

  .back-link {
    font-family: var(--font-condensed);
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--color-text-primary);
  }

  .back-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  .header-body {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 1rem;
  }

  .page-label {
    font-family: var(--font-condensed);
    font-size: 1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.4rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 0.9;
    padding-bottom: 0.5rem;
  }

  .page-number {
    font-family: var(--font-display);
    font-size: clamp(5rem, 12vw, 9rem);
    font-weight: 700;
    color: var(--color-border-subtle);
    line-height: 1;
    padding-bottom: 0.25rem;
    user-select: none;
  }

  /* Body */
  .page-body {
    display: grid;
    grid-template-columns: 2fr 1fr;
    flex: 1;
    border-bottom: 1px solid var(--color-border);
  }

  .col-main {
    border-right: 1px solid var(--color-border);
    padding: 2rem;
  }

  .col-side {
    padding: 2rem;
  }

  /* Footer */
  .page-footer {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-border);
  }

  .footer-col {
    padding: 1.25rem 2rem;
    border-right: 1px solid var(--color-border);
  }

  .footer-col:last-child {
    border-right: none;
  }

  .footer-label {
    font-family: var(--font-condensed);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 0.4rem;
  }

  .footer-value {
    font-family: var(--font-condensed);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .footer-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-text-primary);
  }

  .footer-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 700px) {
    .page-header {
      padding: 1rem 1rem 0;
    }

    .header-body {
      grid-template-columns: 1fr;
    }

    .page-number {
      display: none;
    }

    .page-body {
      grid-template-columns: 1fr;
    }

    .col-main {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 1.5rem 1rem;
    }

    .col-side {
      padding: 1.5rem 1rem;
    }

    .page-footer {
      grid-template-columns: 1fr;
    }

    .footer-col {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 1rem;
    }

    .footer-col:last-child {
      border-bottom: none;
    }
  }
</style>
