---
import PageLayout from "../layouts/PageLayout.astro";

interface MiscSection {
  title: string;
  href: string;
  description: string;
  external?: boolean;
}

const sections: MiscSection[] = [
  {
    title: "Projects",
    href: "/projects",
    description:
      "Side projects, portfolio work, and tools I've built — ZulkirBot, Groovemark, BranchFlow, and more.",
  },
  {
    title: "Writing",
    href: "/writing",
    description:
      "Longer essays, articles, and pieces published outside the blog.",
  },
  {
    title: "Accessibility",
    href: "/accessibility",
    description:
      "My accessibility statement, commitments, and how I approach inclusive design on this site and in my work.",
  },
  {
    title: "Speaking & Podcast",
    href: "/speaking",
    description:
      "22 conference talks, 2 workshops, 21 podcast and stream appearances from 2019 through 2025.",
  },
  {
    title: "Elsewhere",
    href: "/elsewhere",
    description:
      "Where to find me across the web — Bluesky, GitHub, Twitch, and everywhere else.",
  },
  {
    title: "Uses",
    href: "/uses",
    description:
      "The hardware, software, and tools I use day to day for development and streaming.",
  },
  {
    title: "Colophon",
    href: "/colophon",
    description:
      "How this site is built — stack, fonts, hosting, and the decisions behind the design.",
  },
  {
    title: "Privacy",
    href: "/privacy",
    description:
      "What this site does and doesn't collect. Short version: not much.",
  },
];
---

<PageLayout title="Misc — Todd Libby" pageNumber={5} pageLabel="Misc">
  <Fragment slot="main">
    <p class="section-label">Everything else</p>
    <p class="intro-text">
      The pages that don't fit into a single column — projects, writing,
      accessibility, speaking, and the rest.
    </p>

    <ul class="section-list" role="list">
      {
        sections.map((section) => (
          <li class="section-item">
            <a
              href={section.href}
              class="section-link"
              {...(section.external ? { rel: "noopener noreferrer" } : {})}
            >
              <span class="section-title">{section.title}</span>
              <span class="section-arrow" aria-hidden="true">
                &rarr;
              </span>
              <p class="section-desc">{section.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </Fragment>

  <Fragment slot="aside">
    <div class="side-item">
      <p class="section-label">Pages here</p>
      <p class="stat-num">{sections.length}</p>
    </div>

    <div class="side-item">
      <p class="section-label">Quick links</p>
      <ul class="quick-links" aria-label="Quick links to misc pages">
        {
          sections.map((section) => (
            <li>
              <a
                href={section.href}
                class="side-link"
                {...(section.external ? { rel: "noopener noreferrer" } : {})}
              >
                {section.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="side-item">
      <p class="section-label">GitHub</p>
      <a
        href="https://github.com/colabottles"
        class="side-link"
        rel="noopener noreferrer">colabottles</a
      >
    </div>
  </Fragment>
</PageLayout>

<style>
  @import "../styles/page-content.css";

  .section-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .section-item {
    border-bottom: 1px solid #222;
  }

  .section-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.2rem 0.5rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.15s;
  }

  .section-link:hover {
    padding-left: 0.5rem;
  }

  .section-link:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .section-title {
    font-family: "Oswald", sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
    grid-column: 1;
    grid-row: 1;
  }

  .section-arrow {
    font-size: 1rem;
    color: #444;
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    transition:
      color 0.15s,
      transform 0.15s;
  }

  .section-link:hover .section-arrow {
    color: #fff;
    transform: translateX(3px);
  }

  .section-desc {
    font-size: 0.82rem;
    color: #888;
    line-height: 1.55;
    grid-column: 1 / -1;
    grid-row: 2;
    margin: 0;
  }

  .quick-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-top: 0.4rem;
  }
</style>
