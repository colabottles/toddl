---
import Base from "../layouts/Base.astro";
---

<Base title="About">
  <section aria-labelledby="whoami-heading">
    <h1 id="whoami-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> whoami
    </h1>

    <dl class="about-block">
      <div class="about-row">
        <dt class="about-key">location</dt>
        <dd class="about-val">
          Phoenix, AZ <span class="about-comment"
            >// by way of Portland, ME</span
          >
        </dd>
      </div>
      <div class="about-row">
        <dt class="about-key">focus</dt>
        <dd class="about-val">Accessible, semantic web experiences</dd>
      </div>
      <div class="about-row">
        <dt class="about-key">building</dt>
        <dd class="about-val">
          Full-Stack Developer, Nuxt 4, Node, Supabase. Fast, modern apps with
          Postgres &amp; real-time features.
        </dd>
      </div>
      <div class="about-row">
        <dt class="about-key">writing</dt>
        <dd class="about-val">
          <span class="about-comment">// published</span>
        </dd>
      </div>
      <div class="about-row">
        <dt class="about-key">streaming</dt>
        <dd class="about-val">
          <a
            href="https://twitch.tv/toddcodes"
            class="about-link"
            target="_blank"
            rel="noopener noreferrer">toddcodes</a
          >
          <span class="about-comment"> // twitch - web dev</span>
        </dd>
      </div>
      <div class="about-row">
        <dt class="about-key">status</dt>
        <dd class="about-val">available for projects and full-time work</dd>
        <span class="cursor"></span>
      </div>
    </dl>
  </section>

  <hr class="divider" />

  <section aria-labelledby="principles-heading">
    <h2 id="principles-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> cat ./principles
    </h2>

    <ul class="principles-list">
      <li class="principle-item">
        WCAG 2.2 AA compliance is a baseline, not a stretch goal
      </li>
      <li class="principle-item">
        Semantic HTML first - ARIA only when HTML falls short
      </li>
      <li class="principle-item">
        Vanilla CSS over frameworks - precision over convenience
      </li>
      <li class="principle-item">
        Minimal, purposeful changes - no over-engineering
      </li>
    </ul>
  </section>

  <hr class="divider" />

  <section aria-labelledby="bio-heading">
    <h2 id="bio-heading" class="cmd-heading">
      <span class="cmd-prompt">$</span> cat ./bio
    </h2>
    <p class="bio">
      I have spent my career building products and helping companies build
      accessible digital products, leading audits and engineering for
      accessibility-focused organizations, and speaking at conferences on web
      standards and inclusive design. I founded a logistics SaaS company and
      have consulted with businesses of every size on making accessibility a
      culture — not a checkbox. If you need someone who can build, advocate,
      audit, and communicate — that is what I do.
    </p>
  </section>
</Base>

<style>
  .about-block {
    background: var(--warm-mid);
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about-row {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .about-key {
    color: var(--accent);
    min-width: 5rem;
    flex-shrink: 0;
  }

  .about-val {
    color: var(--text-primary);
  }

  .about-comment {
    color: var(--text-secondary);
    font-size: 0.8125rem;
  }

  .about-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .about-link:hover {
    opacity: 0.8;
  }

  /* .cursor {
    display: inline-block;
    width: 7px;
    height: 1em;
    background: var(--accent);
    margin-left: 2px;
    vertical-align: middle;
    animation: blink 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  } */
  .cursor::before {
    content: "|";
  }
  .cursor {
    color: var(--accent);
    display: inline-block;
    margin-left: 2px;
    animation: blink 1.5s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .principles-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .principle-item {
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 0.5rem 0.75rem;
    border: 0.5px solid var(--warm-border);
    border-radius: var(--radius-sm);
    background: var(--warm-mid);
    line-height: 1.5;
  }

  .principle-item::before {
    content: "// ";
    color: var(--accent);
  }

  .inline-code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
  }

  .bio {
    font-size: 0.875rem;
    color: var(--text-primary);
    line-height: 1.75;
    max-width: 65ch;
  }
</style>
